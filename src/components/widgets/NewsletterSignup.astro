---
/**
 * Section newsletter — Bandeau discret d'inscription.
 * Backend : Netlify Function → Brevo API (liste ID 3).
 */
---

<section class="relative py-8 md:py-10 not-prose border-t border-primary-500/10">
  <div class="absolute inset-0 bg-primary-600"></div>
  <div class="relative max-w-2xl mx-auto px-4 sm:px-6">
    <div class="flex flex-col sm:flex-row sm:items-center sm:gap-8">
      <div class="mb-4 sm:mb-0 sm:flex-1 min-w-0">
        <p class="text-sm font-semibold text-white">Restez informés</p>
        <p class="text-xs text-primary-200 mt-0.5">Programme, méditations et nouvelles du Foyer.</p>
      </div>
      <form
        method="POST"
        action="/.netlify/functions/newsletter"
        class="flex gap-2 shrink-0"
      >
        <p class="hidden"><label>Ne pas remplir : <input name="bot-field" /></label></p>
        <input
          type="email"
          name="email"
          required
          aria-label="Adresse e-mail pour la newsletter"
          placeholder="Votre e-mail"
          class="w-48 sm:w-56 px-3 py-2 text-sm bg-white/10 border border-white/20 rounded-lg text-white placeholder-primary-200 focus:outline-none focus:ring-2 focus:ring-accent-400 focus:border-transparent"
        />
        <button
          type="submit"
          class="shrink-0 px-4 py-2 text-sm font-semibold text-primary-900 bg-accent-400 hover:bg-accent-300 rounded-lg transition-colors"
        >
          OK
        </button>
      </form>
    </div>
  </div>
</section>
