---
import Layout from '~/layouts/PageLayout.astro';
import Hero from '~/components/widgets/Hero.astro';
import Content from '~/components/widgets/Content.astro';
import Features from '~/components/widgets/Features.astro';
import CallToAction from '~/components/widgets/CallToAction.astro';
import { getUpcomingEventCount, currentYear } from '~/utils/events';
import fddmFacadeEte from '~/assets/images/fddm-facade-ete.jpg';
import fddmEquipe from '~/assets/images/fddm-equipe-2026.jpg';
import fddmMessePleinAir from '~/assets/images/fddm-messe-plein-air.jpg';
import fddmMarcheGroupe from '~/assets/images/fddm-marche-groupe.jpg';
import fddmLavementPieds from '~/assets/images/fddm-lavement-pieds.jpg';

const eventCount = await getUpcomingEventCount();

const metadata = {
  title: 'Le Foyer de Charité Dents-du-Midi — Accueil spirituel à Bex',
  description: 'Le seul Foyer de Charité en Suisse. Découvrez notre équipe, notre histoire et notre mission d\'accueil spirituel depuis 1970, à Bex, au pied des Dents-du-Midi.',
};
---

<Layout metadata={metadata}>
  <!-- Hero Section -->
  <Hero
    tagline="Bienvenue"
    actions={[
      { variant: 'primary', text: 'Découvrir les retraites', href: '/retraites' },
      { text: 'Notre histoire', href: '/le-foyer/histoire' },
    ]}
  >
    <Fragment slot="title">
      Le Foyer de Charité <span class="text-accent-400">Dents-du-Midi</span>
    </Fragment>

    <Fragment slot="subtitle">
      Nous vous accueillons pour votre retraite spirituelle comme dans une famille.
    </Fragment>

    <Fragment slot="bg">
      <div class="absolute inset-0">
        <img
          src="/images/fddm-automne-2.jpg"
          alt="Le Foyer de Charité dans son parc en automne"
          class="w-full h-full object-cover"
          loading="eager"
        />
        <div class="absolute inset-0 bg-primary-900/60"></div>
      </div>
    </Fragment>
  </Hero>

  <!-- Un lieu d'exception -->
  <Content
    isReversed
    image={{
      src: fddmFacadeEte,
      alt: 'Façade du Foyer de Charité Dents-du-Midi en été',
    }}
  >
    <Fragment slot="content">
      <h2 class="text-2xl font-bold tracking-tight sm:text-3xl mb-2 text-primary-600">
        Un écrin de <span class="text-accent-400">verdure</span>
      </h2>
      <p class="text-muted mb-4">
        En Suisse romande, aux confins sud-est du canton de Vaud dans le Chablais vaudois, Bex est une charmante petite
        bourgade sise au pied des montagnes, dans un écrin de verdure, à quelques kilomètres des rives du lac Léman et
        aux portes du Valais.
      </p>
      <p class="text-muted">
        Il est un autre lieu dans cette commune de Bex, qui ouvre aux profondeurs et donne saveur à la vie : le Foyer
        de Charité Dents-du-Midi — un ancien hôtel transformé en 1970 en lieu d'accueil et de prière, relié à la
        grande famille des Foyers de Charité, fondée en France en 1936.
      </p>
    </Fragment>

    <Fragment slot="bg">
      <div class="absolute inset-0 bg-surface-alt"></div>
    </Fragment>
  </Content>

  <!-- Chiffres clés -->
  <Features
    id="chiffres"
    tagline="En chiffres"
    title="55 ans au service de <span class='text-accent-400'>l'essentiel</span>"
    items={[
      {
        title: '55+ ans',
        description: 'D\'histoire et d\'accueil spirituel depuis 1970',
        icon: 'tabler:calendar-event',
      },
      {
        title: 'Seul en Suisse',
        description: 'L\'unique Foyer de Charité en Suisse',
        icon: 'tabler:map-pin',
      },
      {
        title: '7 hectares',
        description: 'De parc et de forêt, entre prairie et silence',
        icon: 'tabler:trees',
      },
      {
        title: 'Vue sur les Alpes',
        description: 'Chapelle face aux Dents-du-Midi',
        icon: 'tabler:mountain',
      },
      {
        title: `${eventCount} retraites`,
        description: `Programmées en ${currentYear}`,
        icon: 'tabler:book',
      },
      {
        title: 'Équipe dédiée',
        description: 'Prêtre, intendant, communauté et bénévoles',
        icon: 'tabler:users',
      },
    ]}
  />

  <!-- Citation Charte -->
  <section class="px-4 py-16 sm:px-6 mx-auto lg:px-8 lg:py-20 max-w-6xl bg-surface-special">
    <blockquote class="text-center">
      <p class="text-xl md:text-2xl font-medium text-primary-600 mb-6 italic">
        "Hommes et femmes, prêtres et laïcs, mettent en commun leurs biens, leurs compétences et leurs charismes. Par
        leur vie fraternelle et leur accueil, par leur prière et leur travail, ils essaient de vivre concrètement
        l'amour de Dieu, afin d'être des <span class="text-accent-400">'visages de son Amour'</span>."
      </p>
      <cite class="text-muted">— Charte des Foyers de Charité</cite>
    </blockquote>
  </section>

  <!-- L'équipe du Foyer -->
  <Content
    id="equipe"
    isReversed
    image={{
      src: fddmEquipe,
      alt: 'L\'équipe du Foyer de Charité Dents-du-Midi',
    }}
  >
    <Fragment slot="content">
      <h2 class="text-2xl font-bold tracking-tight sm:text-3xl mb-4 text-primary-600">
        L'équipe du <span class="text-accent-400">Foyer</span>
      </h2>
      <p class="text-muted mb-6">
        La petite équipe qui fait vivre le Foyer au quotidien se compose du prêtre du Foyer
        <strong>Guy Luisier</strong>, de l'intendant <strong>Olivier Sudan</strong>,
        de <strong>Giovanna Tassano</strong> venue du Foyer de la Flatière,
        des employées de maison et cuisinière <strong>Sandra</strong>, <strong>Cristina</strong>
        et <strong>Monika</strong>. Depuis le 1<sup>er</sup> février 2026,
        <strong>David La Framboise</strong> a rejoint l'équipe en tant qu'intendant-adjoint.
      </p>

      <h3 class="text-xl font-bold text-primary-600 mb-2">Les « Amis du Foyer »</h3>
      <p class="text-muted mb-6">
        Le Foyer peut compter sur un solide réseau de bénévoles et d'instances bienveillantes œuvrant
        dans et pour le Foyer : participation à l'accueil et au service des retraitants, entretien du parc
        et des bâtiments, travail en cuisine, « services professionnels » offerts, dons de produits
        (légumes, fruits…), animation des célébrations…
      </p>

      <h3 class="text-xl font-bold text-primary-600 mb-2">Les « Conseils »</h3>
      <p class="text-muted">
        La responsabilité de la Maison est assurée par le prêtre du Foyer, l'intendant et le président
        de l'Association « Foyer Dents-du-Midi » <strong>Georges Mariétan</strong> — trio de direction
        soutenu par le Comité de l'Association, le Conseil pastoral et l'Équipe communautaire.
      </p>
    </Fragment>

    <Fragment slot="bg">
      <div class="absolute inset-0 bg-surface-alt"></div>
    </Fragment>
  </Content>

  <!-- Gouvernance -->
  <Features
    id="gouvernance"
    tagline="Organisation"
    title="Une structure <span class='text-accent-400'>collaborative</span>"
    subtitle="Le Foyer est animé par plusieurs organes au service de sa mission d'accueil et de prière."
    items={[
      {
        title: 'Trio de direction',
        description: 'Prêtre du Foyer + Intendant + Président de l\'Association',
        icon: 'tabler:users-group',
      },
      {
        title: 'Comité de l\'Association',
        description: 'Organe de gouvernance de l\'association du Foyer',
        icon: 'tabler:briefcase',
      },
      {
        title: 'Conseil pastoral',
        description: 'Accompagnement spirituel et orientation pastorale',
        icon: 'tabler:heart-handshake',
      },
      {
        title: 'Équipe communautaire',
        description: 'Membres vivant et travaillant au quotidien au Foyer',
        icon: 'tabler:home',
      },
      {
        title: 'Amis du Foyer',
        description: 'Réseau de bénévoles <a href="/soutenir" class="text-primary-600 hover:text-accent-500 underline underline-offset-2">soutenant la mission</a> par leur engagement',
        icon: 'tabler:friends',
      },
      {
        title: 'Personnel',
        description: 'Équipe salariée : cuisine, entretien, accueil',
        icon: 'tabler:tool',
      },
    ]}
  />

  <!-- Nos origines -->
  <Content
    image={{
      src: fddmLavementPieds,
      alt: 'Lavement des pieds lors du Jeudi Saint dans la chapelle du Foyer',
    }}
  >
    <Fragment slot="content">
      <h2 class="text-2xl font-bold tracking-tight sm:text-3xl mb-4 text-primary-600">
        Nos <span class="text-accent-400">origines</span>
      </h2>
      <p class="text-muted mb-4">
        Le Foyer de Charité Dents-du-Midi fut fondé en 1970 par le père Clément Renirkens.
        L'année suivante, Anne-Marie Gavray a rejoint la petite équipe et a été responsable du Foyer
        jusqu'en septembre 2022. Dès 1989, l'abbé Jean-René Fracheboud a accompagné la communauté
        en tant que père du Foyer, jusqu'en janvier 2023.
      </p>
      <p class="text-muted mb-6">
        Ce Foyer, comme tous les autres présents dans le monde, appartient à l'Œuvre internationale
        des Foyers de Charité, reconnue par le Conseil Pontifical pour les laïcs comme
        « Association privée de fidèles de caractère international ».
      </p>
      <a
        href="/le-foyer/histoire"
        class="inline-block bg-accent-400 text-white font-semibold py-3 px-6 rounded-lg hover:bg-accent-500 transition-colors duration-200"
      >
        Découvrir notre histoire complète
      </a>
    </Fragment>
  </Content>

  <!-- Prier au grand air -->
  <Content
    isReversed
    image={{
      src: fddmMessePleinAir,
      alt: 'Célébration eucharistique en plein air sur un alpage, prêtre et retraitants face aux montagnes',
    }}
  >
    <Fragment slot="content">
      <h2 class="text-2xl font-bold tracking-tight sm:text-3xl mb-2 text-primary-600">
        Prier au grand <span class="text-accent-400">air</span>
      </h2>
      <p class="text-muted mb-4">
        La vie au Foyer ne s'arrête pas aux murs du bâtiment. Randonnées, célébrations en plein air,
        moments de partage au cœur de la nature — les montagnes font partie du chemin.
      </p>
      <p class="text-muted">
        L'Eucharistie, célébrée chaque jour, prend parfois des couleurs d'alpage.
      </p>
    </Fragment>

    <Fragment slot="bg">
      <div class="absolute inset-0 bg-surface-alt"></div>
    </Fragment>
  </Content>

  <!-- Rejoindre les Amis -->
  <Content
    items={[
      {
        title: 'Engagement spirituel',
        description: 'Une semaine de service après avoir vécu une <a href="/retraites" class="text-primary-600 hover:text-accent-500 underline underline-offset-2">retraite</a>',
        icon: 'tabler:heart',
      },
      {
        title: 'Missions variées',
        description: 'Service des retraitants, lingerie, jardinage, peinture',
        icon: 'tabler:list-check',
      },
      {
        title: 'Dès 15 ans',
        description: 'Ouvert aux jeunes et adultes de tous âges',
        icon: 'tabler:users',
      },
    ]}
    image={{
      src: fddmMarcheGroupe,
      alt: 'Groupe de retraitants en marche dans les montagnes',
    }}
  >
    <Fragment slot="content">
      <h2 class="text-2xl font-bold tracking-tight sm:text-3xl mb-2 text-primary-600">
        Rejoindre les <span class="text-accent-400">Amis du Foyer</span>
      </h2>
      <p class="text-muted mb-4">
        Vous pouvez contribuer à la vie du Foyer en offrant une semaine de service bénévole. Une expérience de partage
        et de fraternité au cœur de la communauté.
      </p>
      <div class="mt-6">
        <a
          href="/soutenir"
          class="inline-block bg-accent-400 text-white font-semibold py-3 px-6 rounded-lg hover:bg-accent-500 transition-colors duration-200"
        >
          Soutenir le Foyer
        </a>
      </div>
    </Fragment>
  </Content>

  <!-- CTA -->
  <CallToAction
    isDark
    actions={[
      {
        variant: 'primary',
        text: "S'inscrire à une retraite",
        href: '/contact/inscription',
        icon: 'tabler:arrow-right',
      },
      {
        text: 'Voir le programme',
        href: '/programme',
      },
    ]}
  >
    <Fragment slot="title">Venez vivre une <span class="text-accent-400">retraite</span></Fragment>

    <Fragment slot="subtitle">
      Les portes du Foyer sont ouvertes. Inscrivez-vous ou découvrez nos prochaines retraites.<br />
      Personne n'est refusé pour des raisons financières.
    </Fragment>
    <Fragment slot="bg">
      <div class="absolute inset-0 bg-primary-600"></div>
    </Fragment>
  </CallToAction>
</Layout>
