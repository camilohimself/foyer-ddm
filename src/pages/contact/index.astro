---
import Layout from '~/layouts/PageLayout.astro';
import Hero from '~/components/widgets/Hero.astro';
import CallToAction from '~/components/widgets/CallToAction.astro';

const metadata = {
  title: 'Nous contacter — Foyer de Charité Dents-du-Midi',
  description: 'Une question sur nos retraites, le séjour ou l\'inscription ? Contactez le Foyer de Charité Dents-du-Midi à Bex par formulaire, téléphone ou email.',
};
---

<Layout metadata={metadata}>
  <script is:inline type="application/ld+json" set:html={JSON.stringify({
    '@context': 'https://schema.org',
    '@type': 'ContactPage',
    name: 'Contacter le Foyer de Charité Dents-du-Midi',
    url: 'https://foyer-dents-du-midi.ch/contact',
    mainEntity: { '@id': 'https://foyer-dents-du-midi.ch/#organization' },
  })} />

  <Hero tagline="Contact">
    <Fragment slot="title">
      Nous <span class="text-accent-400">contacter</span>
    </Fragment>

    <Fragment slot="subtitle">
      Une question, un renseignement ? Nous vous répondons avec plaisir.
    </Fragment>

    <Fragment slot="bg">
      <div class="absolute inset-0">
        <img
          src="/images/fddm-facade-ete.jpg"
          alt="Le Foyer de Charité Dents-du-Midi en été"
          class="w-full h-full object-cover"
          loading="eager"
        />
        <div class="absolute inset-0 bg-primary-900/60"></div>
      </div>
    </Fragment>
  </Hero>

  <section class="px-4 py-16 sm:px-6 mx-auto lg:px-8 lg:py-20 max-w-5xl">
    <div class="grid md:grid-cols-5 gap-12">

      <!-- Formulaire (3 colonnes) -->
      <div class="md:col-span-3">
        <div class="bg-white shadow-xl rounded-2xl p-8 md:p-10">
          <h2 class="text-2xl font-bold text-primary-600 mb-6">Envoyez-nous un message</h2>

          <form
            name="contact"
            method="POST"
            action="/contact/merci"
            data-netlify="true"
            netlify-honeypot="bot-field"
          >
            <input type="hidden" name="form-name" value="contact" />
            <p class="hidden"><label>Ne remplissez pas : <input name="bot-field" /></label></p>

            <!-- Nom -->
            <div class="mb-5">
              <label for="nom" class="block text-sm font-medium text-gray-700 mb-1">Nom complet <span class="text-red-500">*</span></label>
              <input
                type="text"
                id="nom"
                name="nom"
                required
                autocomplete="name"
                placeholder="Votre nom et prénom"
                class="w-full px-4 py-3 border border-gray-300 rounded-xl focus:ring-2 focus:ring-accent-400 focus:border-transparent transition-shadow"
              />
            </div>

            <!-- Email -->
            <div class="mb-5">
              <label for="email" class="block text-sm font-medium text-gray-700 mb-1">Email <span class="text-red-500">*</span></label>
              <input
                type="email"
                id="email"
                name="email"
                required
                autocomplete="email"
                placeholder="votre.email@exemple.ch"
                class="w-full px-4 py-3 border border-gray-300 rounded-xl focus:ring-2 focus:ring-accent-400 focus:border-transparent transition-shadow"
              />
            </div>

            <!-- Téléphone -->
            <div class="mb-5">
              <label for="telephone" class="block text-sm font-medium text-gray-700 mb-1">Téléphone</label>
              <input
                type="tel"
                id="telephone"
                name="telephone"
                autocomplete="tel"
                placeholder="+41 24 463 22 22"
                class="w-full px-4 py-3 border border-gray-300 rounded-xl focus:ring-2 focus:ring-accent-400 focus:border-transparent transition-shadow"
              />
            </div>

            <!-- Sujet -->
            <div class="mb-5">
              <label for="sujet" class="block text-sm font-medium text-gray-700 mb-1">Sujet <span class="text-red-500">*</span></label>
              <select
                id="sujet"
                name="sujet"
                required
                class="w-full px-4 py-3 border border-gray-300 rounded-xl focus:ring-2 focus:ring-accent-400 focus:border-transparent transition-shadow"
              >
                <option value="" disabled selected>Choisir un sujet</option>
                <option value="Renseignement retraite">Renseignement sur une retraite</option>
                <option value="Inscription">Question sur l'inscription</option>
                <option value="Séjour pratique">Informations pratiques (séjour, accès)</option>
                <option value="Bénévolat">Bénévolat</option>
                <option value="Soutien / don">Soutien ou don</option>
                <option value="Autre">Autre</option>
              </select>
            </div>

            <!-- Message -->
            <div class="mb-6">
              <label for="message" class="block text-sm font-medium text-gray-700 mb-1">Message <span class="text-red-500">*</span></label>
              <textarea
                id="message"
                name="message"
                required
                rows="5"
                placeholder="Votre message..."
                class="w-full px-4 py-3 border border-gray-300 rounded-xl focus:ring-2 focus:ring-accent-400 focus:border-transparent transition-shadow resize-y"
              ></textarea>
            </div>

            <!-- RGPD -->
            <div class="mb-6 flex items-start gap-3">
              <input
                type="checkbox"
                id="rgpd"
                name="rgpd"
                required
                class="mt-1 w-4 h-4 text-accent-400 focus:ring-accent-400 rounded"
              />
              <label for="rgpd" class="text-xs text-gray-500 leading-relaxed cursor-pointer">
                J'accepte que mes données soient traitées pour répondre à ma demande, conformément à la
                <a href="/politique-de-confidentialite" class="text-primary-600 underline underline-offset-2">politique de confidentialité</a>.
              </label>
            </div>

            <!-- Submit -->
            <button
              type="submit"
              class="btn-primary w-full py-3.5 text-base font-semibold rounded-xl shadow-md hover:shadow-lg transition-all"
            >
              Envoyer le message
            </button>
          </form>
        </div>
      </div>

      <!-- Infos latérales (2 colonnes) -->
      <div class="md:col-span-2 space-y-8">

        <!-- Coordonnées -->
        <div class="bg-white shadow-lg rounded-2xl p-6">
          <h3 class="text-lg font-bold text-primary-600 mb-4">Coordonnées</h3>
          <ul class="space-y-4 text-sm text-gray-600">
            <li class="flex items-start gap-3">
              <svg class="w-5 h-5 text-accent-400 mt-0.5 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
              <span>Foyer de Charité Dents-du-Midi<br/>Route de Gryon 22<br/>1880 Bex</span>
            </li>
            <li class="flex items-center gap-3">
              <svg class="w-5 h-5 text-accent-400 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/></svg>
              <a href="tel:+41244632222" class="hover:text-primary-600 transition-colors">+41 24 463 22 22</a>
            </li>
            <li class="flex items-center gap-3">
              <svg class="w-5 h-5 text-accent-400 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/></svg>
              <a href="mailto:info@foyer-dents-du-midi.ch" class="hover:text-primary-600 transition-colors">info@foyer-dents-du-midi.ch</a>
            </li>
          </ul>
        </div>

        <!-- Horaires -->
        <div class="bg-white shadow-lg rounded-2xl p-6">
          <h3 class="text-lg font-bold text-primary-600 mb-4">Accueil</h3>
          <p class="text-sm text-gray-600 leading-relaxed">
            Le secrétariat est joignable du lundi au vendredi, de 9h à 12h et de 14h à 17h.
          </p>
        </div>

        <!-- CTA inscription -->
        <div class="bg-primary-50 rounded-2xl p-6 border border-primary-100">
          <h3 class="text-lg font-bold text-primary-600 mb-2">Vous souhaitez vous inscrire ?</h3>
          <p class="text-sm text-gray-600 mb-4">
            Utilisez notre formulaire d'inscription dédié pour réserver votre place à une retraite.
          </p>
          <a
            href="/contact/inscription"
            class="btn-primary inline-block px-6 py-2.5 text-sm font-semibold rounded-xl"
          >
            S'inscrire à une retraite
          </a>
        </div>
      </div>
    </div>
  </section>

  <CallToAction
    isDark
    actions={[
      {
        variant: 'primary',
        text: 'Voir le programme',
        href: '/programme',
      },
      {
        text: 'Comment venir',
        href: '/sejour/acces',
      },
    ]}
  >
    <Fragment slot="title">Venez vivre l'expérience du <span class="text-accent-400">silence</span></Fragment>
    <Fragment slot="subtitle">
      Le Foyer de Charité Dents-du-Midi vous accueille toute l'année pour des temps de ressourcement.
    </Fragment>
    <Fragment slot="bg">
      <div class="absolute inset-0 bg-primary-600"></div>
    </Fragment>
  </CallToAction>
</Layout>
