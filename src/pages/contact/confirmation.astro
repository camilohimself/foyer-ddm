---
import Layout from '~/layouts/PageLayout.astro';
import Hero from '~/components/widgets/Hero.astro';
import CallToAction from '~/components/widgets/CallToAction.astro';

const metadata = {
  title: 'Demande envoyée',
  description: 'Votre demande d\'inscription a bien été reçue. Un membre du Foyer vous contactera pour confirmer votre place.',
  robots: { index: false, follow: false },
};
---

<Layout metadata={metadata}>
  <Hero
    tagline="Merci"
    title="Demande envoyée"
    subtitle="Votre demande d'inscription a bien été reçue. Elle sera validée par un membre du Foyer."
  >
    <Fragment slot="bg">
      <div class="absolute inset-0">
        <img
          src="/images/fddm-raquettes-dents-du-midi.jpg"
          alt="Groupe de retraitants en raquettes face aux Dents-du-Midi enneigées"
          class="w-full h-full object-cover"
          loading="eager"
        />
        <div class="absolute inset-0 bg-primary-900/60"></div>
      </div>
    </Fragment>
  </Hero>

  <section class="px-4 py-16 sm:px-6 mx-auto lg:px-8 lg:py-20 max-w-3xl">
    <div class="bg-white shadow-xl rounded-2xl p-8 md:p-12">

      <!-- Check icon -->
      <div class="flex justify-center mb-6">
        <div class="w-16 h-16 rounded-full bg-green-100 flex items-center justify-center">
          <svg class="w-8 h-8 text-green-600" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <polyline points="20 6 9 17 4 12"></polyline>
          </svg>
        </div>
      </div>

      <!-- Rappel important -->
      <div class="mb-8 p-4 rounded-xl bg-amber-50 border border-amber-200">
        <p class="text-sm text-amber-800">
          <strong>Important :</strong> votre demande d'inscription n'est <strong>pas encore confirmée</strong>.
          Un membre du Foyer vous contactera par email ou téléphone pour valider votre inscription.
        </p>
      </div>

      <h2 class="text-2xl font-bold text-primary-600 text-center mb-8">Et maintenant ?</h2>

      <!-- Steps -->
      <div class="space-y-6">
        <div class="flex gap-4">
          <div class="flex-shrink-0 w-8 h-8 rounded-full bg-accent-400 text-white flex items-center justify-center text-sm font-bold">1</div>
          <div>
            <h3 class="font-semibold text-primary-600">Examen de votre demande</h3>
            <p class="text-sm text-muted mt-1">Un membre du Foyer examine votre demande et vérifie les disponibilités.</p>
          </div>
        </div>

        <div class="flex gap-4">
          <div class="flex-shrink-0 w-8 h-8 rounded-full bg-accent-400 text-white flex items-center justify-center text-sm font-bold">2</div>
          <div>
            <h3 class="font-semibold text-primary-600">Confirmation personnelle</h3>
            <p class="text-sm text-muted mt-1">Vous serez contacté par email ou téléphone pour confirmer votre inscription et recevoir les détails pratiques.</p>
          </div>
        </div>

        <div class="flex gap-4">
          <div class="flex-shrink-0 w-8 h-8 rounded-full bg-accent-400 text-white flex items-center justify-center text-sm font-bold">3</div>
          <div>
            <h3 class="font-semibold text-primary-600">Préparez votre venue</h3>
            <p class="text-sm text-muted mt-1">Consultez les informations sur <a href="/sejour/acces" class="text-primary-600 hover:text-accent-500 underline underline-offset-2">l'accès</a>, <a href="/sejour/chambres" class="text-primary-600 hover:text-accent-500 underline underline-offset-2">les chambres</a> et <a href="/sejour/journee-type" class="text-primary-600 hover:text-accent-500 underline underline-offset-2">la journée type</a>. Lisez aussi les <a href="/temoignages" class="text-primary-600 hover:text-accent-500 underline underline-offset-2">témoignages</a> de ceux qui sont venus avant vous.</p>
          </div>
        </div>
      </div>

      <!-- Contact info -->
      <div class="mt-8 pt-6 border-t border-gray-100 text-center">
        <p class="text-sm text-muted">
          Une question ? Appelez-nous au <a href="tel:+41244632222" class="text-primary-600 font-medium">+41 24 463 22 22</a>
          ou écrivez à <a href="mailto:info@foyer-dents-du-midi.ch" class="text-primary-600 font-medium">info@foyer-dents-du-midi.ch</a>
        </p>
      </div>
    </div>
  </section>

  <CallToAction
    isDark
    actions={[
      {
        variant: 'primary',
        text: 'Retour à l\'accueil',
        href: '/',
      },
      {
        text: 'Voir le programme',
        href: '/programme',
      },
    ]}
  >
    <Fragment slot="title">Merci de votre <span class="text-accent-400">confiance</span></Fragment>

    <Fragment slot="subtitle">
      Le Foyer de Charité Dents-du-Midi se réjouit de vous accueillir.
    </Fragment>
    <Fragment slot="bg">
      <div class="absolute inset-0 bg-primary-600"></div>
    </Fragment>
  </CallToAction>
</Layout>
