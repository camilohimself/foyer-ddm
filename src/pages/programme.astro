---
import Layout from '~/layouts/PageLayout.astro';
import Hero from '~/components/widgets/Hero.astro';
import CallToAction from '~/components/widgets/CallToAction.astro';
import { getAllEvents, eventsToJsonLd, formatDateRange, today, currentYear } from '~/utils/events';

const events = await getAllEvents();

const metadata = {
  title: `Programme des retraites spirituelles ${currentYear}`,
  description: `${events.length} retraites spirituelles en Suisse au Foyer de Charité Dents-du-Midi, Bex. Retraites de 6 jours, week-ends, journées, couples, familles. Calendrier complet.`,
};

// --- Mapping type → badge + label + href ---
const typeBadge: Record<string, { badge: string; label: string; href: string }> = {
  '6-jours': { badge: 'bg-primary-800', label: '6 jours', href: '/retraites/6-jours' },
  'week-end': { badge: 'bg-primary-500', label: '3 jours', href: '/retraites/week-end' },
  couples: { badge: 'bg-rose-300', label: 'Couples', href: '/retraites/couples' },
  familles: { badge: 'bg-teal-400/80', label: 'Familles', href: '/retraites/familles' },
  journees: { badge: 'bg-accent-400', label: 'Journée', href: '/retraites/journees' },
  mariage: { badge: 'bg-violet-300', label: 'Mariage', href: '/retraites/preparation-mariage' },
};

// --- JSON-LD events data (centralized helper) ---
const jsonLdEvents = eventsToJsonLd(events);

---

<Layout metadata={metadata}>
  {jsonLdEvents.map((schema) => (
    <script type="application/ld+json" set:html={JSON.stringify(schema)} />
  ))}

  <Hero>
    <Fragment slot="title">
      Retraites spirituelles <span class="text-accent-400">{currentYear}</span>
    </Fragment>
    <Fragment slot="subtitle">
      {events.length} retraites de février à septembre au Foyer de Charité Dents-du-Midi, Bex.
      Retraites de 6 jours, week-ends, journées, couples, familles et préparation au mariage.
    </Fragment>
    <Fragment slot="bg">
      <div class="absolute inset-0">
        <img
          src="/images/fddm-contemplation-dents-du-midi.jpg"
          alt="Femme assise contemplant les Dents-du-Midi en été, programme des retraites 2026"
          class="w-full h-full object-cover"
          loading="eager"
        />
        <div class="absolute inset-0 bg-primary-900/60"></div>
      </div>
    </Fragment>
  </Hero>

  <section class="py-12 md:py-20">
    <div class="max-w-5xl mx-auto px-4 sm:px-6">
      <!-- Légende badges -->
      <div class="flex flex-wrap gap-3 mb-8 justify-center">
        <span class="inline-flex items-center gap-1.5 text-sm"><span class="w-3 h-3 rounded-full bg-primary-800"></span> 6 jours</span>
        <span class="inline-flex items-center gap-1.5 text-sm"><span class="w-3 h-3 rounded-full bg-primary-500"></span> 3 jours</span>
        <span class="inline-flex items-center gap-1.5 text-sm"><span class="w-3 h-3 rounded-full bg-accent-400"></span> Journée</span>
        <span class="inline-flex items-center gap-1.5 text-sm"><span class="w-3 h-3 rounded-full bg-rose-300"></span> Couples</span>
        <span class="inline-flex items-center gap-1.5 text-sm"><span class="w-3 h-3 rounded-full bg-teal-400/80"></span> Familles</span>
        <span class="inline-flex items-center gap-1.5 text-sm"><span class="w-3 h-3 rounded-full bg-violet-300"></span> Mariage</span>
      </div>

      <!-- Liste événements -->
      <div class="space-y-4">
        {events.map((event) => {
          const isPast = (event.data.dateEnd || event.data.dateStart) < today;
          const info = typeBadge[event.data.type] || { badge: 'bg-gray-500', label: event.data.type };
          return (
            <div class={`flex flex-col sm:flex-row gap-4 p-5 rounded-lg border border-gray-200 hover:shadow-md transition-shadow bg-white ${isPast ? 'opacity-50' : ''}`}>
              <div class="sm:w-44 shrink-0">
                <div class="text-sm font-semibold text-primary-600">
                  {formatDateRange(event.data.dateStart, event.data.dateEnd)}
                </div>
                <a href={info.href} class={`inline-block mt-1 text-xs font-medium text-white px-2.5 py-0.5 rounded-full ${info.badge} hover:opacity-80 transition-opacity`}>
                  {info.label} →
                </a>
                {isPast && <span class="inline-block ml-1 text-xs text-gray-400">(passée)</span>}
              </div>
              <div class="flex-1">
                <h3 class="text-lg font-semibold text-primary-600">{event.data.title}</h3>
                <p class="text-sm text-muted mt-1">
                  {event.data.preacher}
                  {event.data.variant && <span class="ml-2 text-accent-500 font-medium">· {event.data.variant}</span>}
                </p>
              </div>
              <div class="sm:self-center shrink-0">
                {isPast ? (
                  <span class="inline-flex items-center justify-center text-sm font-medium text-gray-400 px-4 py-2">Terminée</span>
                ) : event.data.externalUrl ? (
                  <a
                    href={event.data.externalUrl}
                    target="_blank"
                    rel="noopener noreferrer"
                    class="inline-flex items-center justify-center text-sm font-semibold bg-accent-400 text-white px-4 py-2 rounded-full hover:bg-accent-300 transition"
                  >
                    S'inscrire ↗
                  </a>
                ) : (
                  <a
                    href={`/contact/inscription?retraite=${event.id}`}
                    class="inline-flex items-center justify-center text-sm font-semibold bg-accent-400 text-white px-4 py-2 rounded-full hover:bg-accent-300 transition"
                  >
                    S'inscrire
                  </a>
                )}
              </div>
            </div>
          );
        })}
      </div>
    </div>
  </section>

  <CallToAction
    isDark
    actions={[
      {
        variant: 'primary',
        text: "S'inscrire à une retraite",
        href: '/contact/inscription',
        icon: 'tabler:arrow-right',
      },
      {
        text: 'Nous contacter',
        href: '/contact',
      },
    ]}
  >
    <Fragment slot="title">
      Franchir le <span class="text-accent-400">pas</span>
    </Fragment>
    <Fragment slot="subtitle">
      Les portes du Foyer sont ouvertes. Inscrivez-vous ou contactez-nous pour toute question.<br />
      Personne n'est refusé pour des raisons financières.
    </Fragment>
    <Fragment slot="bg">
      <div class="absolute inset-0 bg-primary-600"></div>
    </Fragment>
  </CallToAction>
</Layout>
