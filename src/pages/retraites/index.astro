---
import Layout from '~/layouts/PageLayout.astro';
import Hero from '~/components/widgets/Hero.astro';
import Features2 from '~/components/widgets/Features2.astro';
import Content from '~/components/widgets/Content.astro';
import CallToAction from '~/components/widgets/CallToAction.astro';
import { getUpcomingEventCount, currentYear } from '~/utils/events';

import imgEnseignementAlpage from '~/assets/images/fddm-enseignement-alpage.jpg';

const eventCount = await getUpcomingEventCount();

const metadata = {
  title: 'Retraites spirituelles en Suisse romande — Foyer de Charité, Bex',
  description: 'Retraites spirituelles en Suisse romande : journées, week-ends, retraites de 6 jours et préparation au mariage. Foyer de Charité Dents-du-Midi, Bex.',
};
---

<Layout metadata={metadata}>
  <Hero>
    <Fragment slot="title">
      Nos <span class="text-accent-400">retraites spirituelles</span> en Suisse
    </Fragment>
    <Fragment slot="subtitle">
      De la journée de découverte à la retraite de six jours, plusieurs chemins s'offrent à vous.
      Il y a toujours une place pour qui ressent le besoin de faire une pause.
    </Fragment>
    <Fragment slot="bg">
      <div class="absolute inset-0">
        <img
          src="/images/fddm-chapelle-etoile.jpg"
          alt="La chapelle du Foyer illuminée, porte d'entrée vers les retraites spirituelles"
          class="w-full h-full object-cover"
          loading="eager"
        />
        <div class="absolute inset-0 bg-primary-900/60"></div>
      </div>
    </Fragment>
  </Hero>

  <Features2
    title="Chaque retraite, un chemin"
    subtitle="L'accueil, les repas, les enseignements et l'accompagnement spirituel font partie de chaque retraite."
    items={[
      {
        title: 'Une journée au Foyer',
        description: 'De 9h30 à 16h30. Enseignements, repas partagé et Eucharistie. Une porte d\'entrée toute simple pour découvrir le Foyer.',
        icon: 'tabler:sun',
        callToAction: { text: 'Découvrir', href: '/retraites/journees' },
      },
      {
        title: 'Week-ends',
        description: 'Du vendredi soir au dimanche après-midi. Pour tous, en couple ou en famille. Une pause au cœur de votre quotidien pour se ressourcer.',
        icon: 'tabler:calendar-event',
        callToAction: { text: 'Découvrir', href: '/retraites/week-ends' },
      },
      {
        title: 'Six jours de silence',
        description: 'Du dimanche soir au samedi matin. Le format historique des Foyers : six jours pour avancer dans la foi, portés par les enseignements et le silence.',
        icon: 'tabler:sunset-2',
        callToAction: { text: 'Découvrir', href: '/retraites/6-jours' },
      },
      {
        title: 'Préparation au mariage',
        description: 'Un week-end pour préparer votre engagement, accompagnés par des couples animateurs et un prêtre. Organisation : Diocèse de Sion.',
        icon: 'tabler:rings',
        callToAction: { text: 'Découvrir', href: '/retraites/preparation-mariage' },
      },
    ]}
  >
    <Fragment slot="bg">
      <div class="absolute inset-0 bg-surface-alt"></div>
    </Fragment>
  </Features2>

  <Content
    tagline="Par où commencer ?"
    title="Chacun vient comme il est"
    image={{
      src: imgEnseignementAlpage,
      alt: 'Enseignement en plein air sur un alpage, groupe de retraitants assis en cercle face aux montagnes',
    }}
    items={[
      {
        title: 'C\'est la première fois ?',
        description: 'Une <a href="/retraites/journees" class="text-primary-600 hover:text-accent-500 underline underline-offset-2">journée</a> ou un <a href="/retraites/week-ends" class="text-primary-600 hover:text-accent-500 underline underline-offset-2">week-end</a> : un premier pas, sans engagement, pour découvrir ce que le silence peut offrir.',
      },
      {
        title: 'Aller plus loin ?',
        description: 'La <a href="/retraites/6-jours" class="text-primary-600 hover:text-accent-500 underline underline-offset-2">retraite de six jours</a> est le cœur de la tradition des Foyers de Charité. Six jours de silence pour un nouveau souffle.',
      },
      {
        title: 'En couple ou en famille ?',
        description: 'Des <a href="/retraites/week-ends" class="text-primary-600 hover:text-accent-500 underline underline-offset-2">week-ends</a> pensés pour cheminer ensemble : <a href="/retraites/week-ends#en-couple" class="text-primary-600 hover:text-accent-500 underline underline-offset-2">en couple</a> ou <a href="/retraites/week-ends#en-famille" class="text-primary-600 hover:text-accent-500 underline underline-offset-2">en famille</a>. Vos enfants sont accueillis avec un programme adapté à leur âge.',
      },
      {
        title: 'Préparer votre mariage ?',
        description: 'Un <a href="/retraites/preparation-mariage" class="text-primary-600 hover:text-accent-500 underline underline-offset-2">week-end de préparation au mariage</a> pour poser les fondations de votre engagement, accompagnés par des couples et un prêtre.',
      },
    ]}
  >
    <Fragment slot="content">
      <h3 class="text-2xl font-bold tracking-tight sm:text-3xl mb-2 text-primary-600">
        Un pas à la fois
      </h3>
      Que vous veniez pour la première fois ou que vous connaissiez déjà le Foyer, il y a une retraite pour vous.
      Aucune situation financière ne doit être un obstacle.
    </Fragment>
  </Content>

  <CallToAction
    isDark
    actions={[
      {
        variant: 'primary',
        text: `Voir le programme ${currentYear}`,
        href: '/programme',
        icon: 'tabler:calendar',
      },
      {
        text: "S'inscrire",
        href: '/contact/inscription',
      },
    ]}
  >
    <Fragment slot="title">
      {eventCount} retraites en <span class="text-accent-400">{currentYear}</span>
    </Fragment>
    <Fragment slot="subtitle">
      De février à septembre, retrouvez notre programme complet avec dates, thèmes et prédicateurs.
    </Fragment>
    <Fragment slot="bg">
      <div class="absolute inset-0 bg-primary-600"></div>
    </Fragment>
  </CallToAction>
</Layout>
