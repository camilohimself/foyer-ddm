---
import Layout from '~/layouts/PageLayout.astro';
import Hero from '~/components/widgets/Hero.astro';
import Content from '~/components/widgets/Content.astro';
import CallToAction from '~/components/widgets/CallToAction.astro';
import Image from '~/components/common/Image.astro';
import { getUpcomingEventCount, currentYear } from '~/utils/events';

import imgEnseignementAlpage from '~/assets/images/fddm-enseignement-alpage.jpg';
import fddmEnseignement from '~/assets/images/fddm-enseignement-alpage.jpg';
import fddmArcabasCroix from '~/assets/images/fddm-arcabas-croix.jpg';
import fddmCroix from '~/assets/images/fddm-croix-sommet.jpg';
import fddmCouple from '~/assets/images/fddm-couple-mains.jpg';

const eventCount = await getUpcomingEventCount();

const metadata = {
  title: 'Retraites spirituelles en Suisse romande — Foyer de Charité, Bex',
  description: 'Retraites spirituelles en Suisse romande : journées, week-ends, retraites de 6 jours et préparation au mariage. Foyer de Charité Dents-du-Midi, Bex.',
};
---

<Layout metadata={metadata}>
  <Hero>
    <Fragment slot="title">
      Nos <span class="text-accent-400">retraites spirituelles</span> en Suisse
    </Fragment>
    <Fragment slot="subtitle">
      De la journée de découverte à la retraite de six jours, plusieurs chemins s'offrent à vous.
      Il y a toujours une place pour qui ressent le besoin de faire une pause.
    </Fragment>
    <Fragment slot="bg">
      <div class="absolute inset-0">
        <img
          src="/images/fddm-chapelle-etoile.jpg"
          alt="La chapelle du Foyer illuminée, porte d'entrée vers les retraites spirituelles"
          class="w-full h-full object-cover"
          loading="eager"
        />
        <div class="absolute inset-0 bg-primary-900/60"></div>
      </div>
    </Fragment>
  </Hero>

  <!-- Nos retraites — Cartes photo -->
  <section class="py-16 md:py-24 relative">
    <div class="absolute inset-0 bg-surface-alt"></div>
    <div class="relative max-w-6xl mx-auto px-4 sm:px-6">
      <div class="text-center mb-12">
        <h2 class="text-4xl md:text-5xl font-playball text-primary-600">Chaque retraite, un chemin</h2>
        <p class="text-muted mt-4 max-w-2xl mx-auto">L'accueil, les repas, les enseignements et l'accompagnement font partie de chaque retraite.</p>
      </div>

      <div class="grid sm:grid-cols-2 gap-6 md:gap-8">
        <a href="/retraites/journees" class="group block rounded-2xl overflow-hidden border border-gray-200 bg-white hover:shadow-xl hover:border-accent-300 transition-all duration-300">
          <div class="overflow-hidden">
            <Image src={fddmEnseignement} alt="Enseignement en plein air sur un alpage" width={640} height={360} class="w-full h-52 md:h-64 object-cover group-hover:scale-105 transition-transform duration-500" loading="lazy" />
          </div>
          <div class="p-6 md:p-8">
            <h3 class="text-xl md:text-2xl font-bold text-primary-600 group-hover:text-accent-500 transition-colors mb-3">Journées de ressourcement</h3>
            <p class="text-muted text-sm md:text-base leading-relaxed mb-4">Une journée pour prier, se laisser inspirer, respirer. À partir d'un personnage de la Bible, d'un témoin de la foi, d'un écrivain ou d'un poète.</p>
            <span class="inline-flex items-center gap-2 text-accent-500 font-semibold text-sm group-hover:text-accent-400 transition-colors">
              Découvrir
              <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 group-hover:translate-x-1 transition-transform" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
            </span>
          </div>
        </a>

        <a href="/retraites/week-ends" class="group block rounded-2xl overflow-hidden border border-gray-200 bg-white hover:shadow-xl hover:border-accent-300 transition-all duration-300">
          <div class="overflow-hidden">
            <Image src={fddmArcabasCroix} alt="Peinture d'Arcabas — croix et lumière, tons ocre et bleu" width={640} height={360} class="w-full h-52 md:h-64 object-cover group-hover:scale-105 transition-transform duration-500" loading="lazy" />
          </div>
          <div class="p-6 md:p-8">
            <h3 class="text-xl md:text-2xl font-bold text-primary-600 group-hover:text-accent-500 transition-colors mb-3">Week-ends</h3>
            <p class="text-muted text-sm md:text-base leading-relaxed mb-4">Une pause au cœur de votre quotidien ! Trois jours pour vivre une halte spirituelle — seul, en couple ou en famille.</p>
            <span class="inline-flex items-center gap-2 text-accent-500 font-semibold text-sm group-hover:text-accent-400 transition-colors">
              Découvrir
              <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 group-hover:translate-x-1 transition-transform" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
            </span>
          </div>
        </a>

        <a href="/retraites/6-jours" class="group block rounded-2xl overflow-hidden border border-gray-200 bg-white hover:shadow-xl hover:border-accent-300 transition-all duration-300">
          <div class="overflow-hidden">
            <Image src={fddmCroix} alt="Croix au sommet avec vue sur les Dents-du-Midi" width={640} height={360} class="w-full h-52 md:h-64 object-cover group-hover:scale-105 transition-transform duration-500" loading="lazy" />
          </div>
          <div class="p-6 md:p-8">
            <h3 class="text-xl md:text-2xl font-bold text-primary-600 group-hover:text-accent-500 transition-colors mb-3">Six jours de silence</h3>
            <p class="text-muted text-sm md:text-base leading-relaxed mb-4">Le format historique des Foyers de Charité. Six jours pour avancer dans la foi, portés par les enseignements et le silence.</p>
            <span class="inline-flex items-center gap-2 text-accent-500 font-semibold text-sm group-hover:text-accent-400 transition-colors">
              Découvrir
              <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 group-hover:translate-x-1 transition-transform" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
            </span>
          </div>
        </a>

        <a href="/retraites/preparation-mariage" class="group block rounded-2xl overflow-hidden border border-gray-200 bg-white hover:shadow-xl hover:border-accent-300 transition-all duration-300">
          <div class="overflow-hidden">
            <Image src={fddmCouple} alt="Mains jointes d'un couple" width={640} height={360} class="w-full h-52 md:h-64 object-cover group-hover:scale-105 transition-transform duration-500" loading="lazy" />
          </div>
          <div class="p-6 md:p-8">
            <h3 class="text-xl md:text-2xl font-bold text-primary-600 group-hover:text-accent-500 transition-colors mb-3">Préparation au mariage</h3>
            <p class="text-muted text-sm md:text-base leading-relaxed mb-4">Approfondir le sens de l'engagement. Deux jours accompagnés par des couples animateurs et un prêtre. Organisation : Diocèse de Sion.</p>
            <span class="inline-flex items-center gap-2 text-accent-500 font-semibold text-sm group-hover:text-accent-400 transition-colors">
              Découvrir
              <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 group-hover:translate-x-1 transition-transform" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
            </span>
          </div>
        </a>
      </div>
    </div>
  </section>

  <Content
    tagline="Par où commencer ?"
    title="Chacun vient comme il est"
    image={{
      src: imgEnseignementAlpage,
      alt: 'Enseignement en plein air sur un alpage, groupe de retraitants assis en cercle face aux montagnes',
    }}
    items={[
      {
        title: 'C\'est la première fois ?',
        description: 'Une <a href="/retraites/journees" class="text-primary-600 hover:text-accent-500 underline underline-offset-2">journée</a> ou un <a href="/retraites/week-ends" class="text-primary-600 hover:text-accent-500 underline underline-offset-2">week-end</a> : un premier pas, sans engagement, pour découvrir ce que le silence peut offrir.',
      },
      {
        title: 'Aller plus loin ?',
        description: 'La <a href="/retraites/6-jours" class="text-primary-600 hover:text-accent-500 underline underline-offset-2">retraite de six jours</a> est le cœur de la tradition des Foyers de Charité. Six jours de silence pour un nouveau souffle.',
      },
      {
        title: 'En couple ou en famille ?',
        description: 'Des <a href="/retraites/week-ends" class="text-primary-600 hover:text-accent-500 underline underline-offset-2">week-ends</a> pensés pour cheminer ensemble : <a href="/retraites/week-ends#en-couple" class="text-primary-600 hover:text-accent-500 underline underline-offset-2">en couple</a> ou <a href="/retraites/week-ends#en-famille" class="text-primary-600 hover:text-accent-500 underline underline-offset-2">en famille</a>. Vos enfants sont accueillis avec un programme adapté à leur âge.',
      },
      {
        title: 'Préparer votre mariage ?',
        description: 'Un <a href="/retraites/preparation-mariage" class="text-primary-600 hover:text-accent-500 underline underline-offset-2">week-end de préparation au mariage</a> pour poser les fondations de votre engagement, accompagnés par des couples et un prêtre.',
      },
    ]}
  >
    <Fragment slot="content">
      <h3 class="text-2xl font-bold tracking-tight sm:text-3xl mb-2 text-primary-600">
        Un pas à la fois
      </h3>
      Que vous veniez pour la première fois ou que vous connaissiez déjà le Foyer, il y a une retraite pour vous.
      Aucune situation financière ne doit être un obstacle.
    </Fragment>
  </Content>

  <CallToAction
    isDark
    actions={[
      {
        variant: 'primary',
        text: `Voir le programme ${currentYear}`,
        href: '/programme',
        icon: 'tabler:calendar',
      },
      {
        text: "S'inscrire",
        href: '/contact/inscription',
      },
    ]}
  >
    <Fragment slot="title">
      {eventCount} retraites en <span class="text-accent-400">{currentYear}</span>
    </Fragment>
    <Fragment slot="subtitle">
      De février à septembre, retrouvez notre programme complet avec dates, thèmes et intervenants.
    </Fragment>
    <Fragment slot="bg">
      <div class="absolute inset-0 bg-primary-600"></div>
    </Fragment>
  </CallToAction>
</Layout>
