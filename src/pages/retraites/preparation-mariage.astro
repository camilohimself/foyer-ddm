---
import Layout from '~/layouts/PageLayout.astro';
import Hero from '~/components/widgets/Hero.astro';
import Content from '~/components/widgets/Content.astro';
import Steps from '~/components/widgets/Steps.astro';
import Features from '~/components/widgets/Features.astro';
import Testimonials from '~/components/widgets/Testimonials.astro';
import CallToAction from '~/components/widgets/CallToAction.astro';
import { getUpcomingEvents, eventsToStepsItems, eventsToJsonLd, currentYear } from '~/utils/events';

import imgChapelleCroix from '~/assets/images/fddm-chapelle-croix.jpg';

const upcomingMariage = await getUpcomingEvents('mariage');
const stepsItems = eventsToStepsItems(upcomingMariage);
const jsonLdEvents = eventsToJsonLd(upcomingMariage);

const metadata = {
  title: 'Préparation au mariage chrétien — Week-end en Suisse',
  description: 'Préparation au mariage chrétien en Suisse romande. Approfondir le sens de l\'engagement, accompagnés par des couples animateurs et un prêtre. Organisation : Diocèse de Sion. Foyer de Charité, Bex.',
};
---

<Layout metadata={metadata}>
  {jsonLdEvents.map((schema) => (
    <script type="application/ld+json" set:html={JSON.stringify(schema)} />
  ))}

  <Hero>
    <Fragment slot="title">
      Approfondir le sens de <span class="text-accent-400">l'engagement</span>
    </Fragment>
    <Fragment slot="subtitle">
      Deux jours pour aborder les thèmes essentiels de l'engagement dans le mariage, accompagnés par des couples animateurs et un prêtre.
    </Fragment>
    <Fragment slot="bg">
      <div class="absolute inset-0">
        <img
          src="/images/fddm-couple-mains.jpg"
          alt="Mains jointes d'un couple, préparation au mariage au Foyer"
          class="w-full h-full object-cover"
          loading="eager"
        />
        <div class="absolute inset-0 bg-primary-900/60"></div>
      </div>
    </Fragment>
  </Hero>

  <Content
    tagline="Le format"
    title="Préparer votre engagement"
    image={{
      src: imgChapelleCroix,
      alt: 'La croix dans la chapelle du Foyer, lieu de préparation au sacrement du mariage',
    }}
    items={[
      {
        title: 'Deux jours complets',
        description: 'Samedi et dimanche pour aborder les thèmes essentiels de l\'engagement dans le mariage.',
      },
      {
        title: 'Organisation : Diocèse de Sion',
        description: 'Accompagnés par des couples animateurs et un prêtre. Possibilité de dormir sur place. <a href="https://diocese-sion.ch/evenement/week-end-preparation-au-mariage-1-20260926" target="_blank" rel="noopener noreferrer" class="text-primary-600 hover:text-accent-500 underline underline-offset-2">Toutes les infos</a>.',
      },
      {
        title: 'Plusieurs formules disponibles',
        description: 'Week-ends, journées ou soirées. Consultez le <a href="https://diocese-sion.ch/recevoir-un-sacrement/mariage" target="_blank" rel="noopener noreferrer" class="text-primary-600 hover:text-accent-500 underline underline-offset-2">Diocèse de Sion</a> pour toutes les options.',
      },
    ]}
  >
    <Fragment slot="content">
      <h3 class="text-2xl font-bold tracking-tight sm:text-3xl mb-2 text-primary-600">
        Approfondir le sens de l'engagement
      </h3>
      Deux jours pour aborder les thèmes essentiels de l'engagement dans le mariage,
      accompagnés par des couples animateurs et un prêtre.
    </Fragment>
    <Fragment slot="bg">
      <div class="absolute inset-0 bg-surface-alt"></div>
    </Fragment>
  </Content>

  <Steps
    title={`Prochaines dates ${currentYear}`}
    items={stepsItems}
  />

  <div class="text-center -mt-4 mb-8">
    <a href="/programme" class="inline-flex items-center gap-2 text-primary-600 hover:text-accent-500 font-semibold transition-colors">
      Voir tout le programme {currentYear}
      <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
    </a>
  </div>

  <Content
    tagline="Le programme"
    title="Thèmes abordés durant le week-end"
    items={[
      {
        title: 'Le sacrement du mariage',
        description: 'Sens spirituel et théologique de l\'engagement. Préparation liturgique de la célébration.',
      },
      {
        title: 'Dialogue et communication',
        description: 'Apprendre à se parler, s\'écouter, se comprendre. Exercices pratiques en couple.',
      },
      {
        title: 'Pardon et réconciliation',
        description: 'Gérer les conflits, demander pardon, reconstruire après les blessures.',
      },
      {
        title: 'Vie conjugale et affectivité',
        description: 'Corps, affectivité, sexualité dans le mariage chrétien.',
      },
      {
        title: 'Education et transmission',
        description: 'Projet éducatif, transmission de la foi aux enfants.',
      },
      {
        title: 'Vie matérielle et spirituelle',
        description: 'Budget, organisation du foyer, place de la prière dans le couple.',
      },
    ]}
  >
    <Fragment slot="content">
      <h3 class="text-2xl font-bold tracking-tight sm:text-3xl mb-2 text-primary-600">
        Les thèmes abordés
      </h3>
      Tous les aspects de la vie conjugale sont abordés : spirituels, humains, pratiques. Avec des temps d'enseignement,
      de dialogue à deux et de partage en groupe.
    </Fragment>
    <Fragment slot="bg">
      <div class="absolute inset-0 bg-surface-special"></div>
    </Fragment>
  </Content>

  <Features
    title="Informations pratiques"
    subtitle="Liens utiles pour préparer votre mariage"
    items={[
      {
        title: 'Diocèse de Sion',
        description: 'Information sur le sacrement du mariage dans le diocèse.',
        icon: 'tabler:external-link',
        callToAction: { text: 'Consulter', href: 'https://diocese-sion.ch/recevoir-un-sacrement/mariage', target: '_blank' },
      },
      {
        title: 'Suisse Romande',
        description: 'Portail de la pastorale familiale en Suisse Romande.',
        icon: 'tabler:external-link',
        callToAction: { text: 'Consulter', href: 'https://preparation-au-mariage.pastorale-familiale.ch/', target: '_blank' },
      },
      {
        title: 'Canton de Vaud',
        description: 'Informations pour les mariages dans le canton de Vaud.',
        icon: 'tabler:external-link',
        callToAction: { text: 'Consulter', href: 'https://www.cath-vd.ch/etapes_de_la_vie/mariage/', target: '_blank' },
      },
    ]}
  >
    <Fragment slot="bg">
      <div class="absolute inset-0 bg-surface-alt"></div>
    </Fragment>
  </Features>

  <Testimonials
    title="Paroles de futurs mariés"
    testimonials={[
      {
        testimonial: `Ses paroles nous ont touchés en profondeur.`,
        name: 'Claire et Pierre',
        job: 'Futurs mariés',
      },
      {
        testimonial: `La beauté simple de ce lieu sait si bien chanter Dieu !`,
        name: 'P. et R.G.',
        job: 'Couple marié',
      },
    ]}
  >
    <Fragment slot="bg">
      <div class="absolute inset-0 bg-surface-special"></div>
    </Fragment>
  </Testimonials>

  <!-- Maillage interne : infos pratiques -->
  <section class="py-8">
    <div class="max-w-3xl mx-auto px-4 sm:px-6 text-center">
      <p class="text-sm text-muted">
        Avant de vous inscrire, découvrez
        <a href="/sejour/acces" class="text-primary-600 hover:text-accent-500 underline underline-offset-2">comment venir</a>.
        Vous pouvez aussi consulter le <a href="/programme" class="text-primary-600 hover:text-accent-500 underline underline-offset-2">programme complet</a>.
      </p>
    </div>
  </section>

  <CallToAction
    isDark
    actions={[
      {
        variant: 'primary',
        text: "S'inscrire (Diocèse de Sion)",
        href: 'https://forms.office.com/pages/responsepage.aspx?id=81Sd6g7JkUGV-WbmeWHcoI9uUpWWcfhHkUpCzhckVcBUMVdVU0xURU5RSFlHS1NLMks5UUJOUEdBOC4u&origin=lprLink&route=shorturl',
        target: '_blank',
        icon: 'tabler:external-link',
      },
      {
        text: 'Découvrir les autres retraites',
        href: '/retraites',
      },
    ]}
  >
    <Fragment slot="title">
      Préparer votre <span class="text-accent-400">mariage</span>
    </Fragment>
    <Fragment slot="subtitle">
      Inscrivez-vous pour la prochaine session via le formulaire du Diocèse de Sion.
    </Fragment>
    <Fragment slot="bg">
      <div class="absolute inset-0 bg-primary-600"></div>
    </Fragment>
  </CallToAction>
</Layout>
