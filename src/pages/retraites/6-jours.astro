---
import Layout from '~/layouts/PageLayout.astro';
import Hero from '~/components/widgets/Hero.astro';
import Content from '~/components/widgets/Content.astro';
import Steps from '~/components/widgets/Steps.astro';
import Testimonials from '~/components/widgets/Testimonials.astro';
import CallToAction from '~/components/widgets/CallToAction.astro';
import { getUpcomingEvents, eventsToStepsItems, eventsToJsonLd, currentYear } from '~/utils/events';

import imgAutelHiver from '~/assets/images/fddm-autel-hiver.jpg';

const upcoming6jours = await getUpcomingEvents('6-jours');
const stepsItems = eventsToStepsItems(upcoming6jours);
const jsonLdEvents = eventsToJsonLd(upcoming6jours);

const metadata = {
  title: 'Retraite spirituelle de 6 jours en Suisse — Silence et enseignements',
  description: 'Retraite spirituelle de 6 jours en Suisse romande. Silence, enseignements, accompagnement individuel face aux Alpes. Foyer de Charité Dents-du-Midi, Bex.',
};
---

<Layout metadata={metadata}>
  {jsonLdEvents.map((schema) => (
    <script is:inline type="application/ld+json" set:html={JSON.stringify(schema)} />
  ))}

  <Hero>
    <Fragment slot="title">
      Retraite spirituelle de <span class="text-accent-400">6 jours</span>
    </Fragment>
    <Fragment slot="subtitle">
      Six jours de silence pour avancer dans la foi, portés par les enseignements d'un intervenant. Le cœur de la tradition des Foyers de Charité.
    </Fragment>
    <Fragment slot="bg">
      <div class="absolute inset-0">
        <img
          src="/images/fddm-croix-sommet.jpg"
          alt="Retraite spirituelle de 6 jours — croix au sommet face aux Dents-du-Midi"
          class="w-full h-full object-cover"
          loading="eager"
        />
        <div class="absolute inset-0 bg-primary-900/60"></div>
      </div>
    </Fragment>
  </Hero>

  <Content
    tagline="Le format"
    title="Six jours pour aller à l'essentiel"
    image={{
      src: imgAutelHiver,
      alt: "L'autel de la chapelle en hiver, lieu de recueillement quotidien",
    }}
    items={[
      {
        title: 'Du dimanche soir au samedi matin',
        description: 'L\'arrivée se fait le dimanche avec l\'Eucharistie dominicale à 18h, suivie du repas à 19h.',
      },
      {
        title: 'Un thème pour chaque retraite',
        description: 'Un témoin de la foi, des paroles bibliques, un temps de l\'année liturgique, une dimension essentielle de la vie de foi...',
      },
      {
        title: 'En silence',
        description: 'Le silence favorise le ressourcement de chacun par le repos, l\'intériorité et le respect du cheminement de chacun.',
      },
      {
        title: 'Accompagnement personnel',
        description: 'Possibilité d\'un entretien personnel avec un prêtre. L\'Eucharistie (messe) quotidienne. L\'adoration.',
      },
    ]}
  >
    <Fragment slot="content">
      <h3 class="text-2xl font-bold tracking-tight sm:text-3xl mb-2 text-primary-600">
        Un itinéraire spirituel
      </h3>
      Six jours d'enseignements, de prière et de vie communautaire.
      Un temps qui se vit en silence pour favoriser le calme, le recueillement
      et le respect du cheminement de chacun.
    </Fragment>
    <Fragment slot="bg">
      <div class="absolute inset-0 bg-surface-alt"></div>
    </Fragment>
  </Content>

  <Steps
    title={`Prochaines dates ${currentYear}`}
    items={stepsItems}
  />

  <div class="text-center -mt-4 mb-8">
    <a href="/programme" class="inline-flex items-center gap-2 text-primary-600 hover:text-accent-500 font-semibold transition-colors">
      Voir tout le programme {currentYear}
      <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
    </a>
  </div>

  <Content
    tagline="Une journée type"
    title="Le rythme d'une retraite"
    items={[
      {
        title: '8h00 — Lever',
        description: 'Début de la journée en douceur.',
        icon: 'tabler:sunrise',
      },
      {
        title: '8h30 — Louange du matin',
        description: 'Prière communautaire pour ouvrir la journée.',
        icon: 'tabler:heart',
      },
      {
        title: '8h50 — Petit déjeuner',
        description: 'Premier repas, dans le silence.',
        icon: 'tabler:coffee',
      },
      {
        title: '9h45 — Conférence',
        description: 'Enseignement spirituel donné par l\'intervenant de la retraite.',
        icon: 'tabler:book-2',
      },
      {
        title: '11h00 — Adoration',
        description: 'Temps de prière silencieuse devant le Saint-Sacrement.',
        icon: 'tabler:candle',
      },
      {
        title: '12h30 — Repas',
        description: 'Repas de midi, en silence.',
        icon: 'tabler:tools-kitchen-2',
      },
      {
        title: '15h00 — Thé',
        description: 'Pause conviviale.',
        icon: 'tabler:cup',
      },
      {
        title: '15h30 — Conférence',
        description: 'Deuxième enseignement de la journée.',
        icon: 'tabler:book',
      },
      {
        title: '17h30 — Eucharistie',
        description: 'Célébration de la messe, sommet de la journée.',
        icon: 'tabler:star',
      },
      {
        title: '19h00 — Repas',
        description: 'Souper en commun.',
        icon: 'tabler:tools-kitchen',
      },
      {
        title: '20h30 — Prière du soir',
        description: 'Prière communautaire pour clôturer la journée.',
        icon: 'tabler:moon',
      },
    ]}
  >
    <Fragment slot="content">
      <h3 class="text-2xl font-bold tracking-tight sm:text-3xl mb-2 text-primary-600">
        Le rythme d'une <span class="text-accent-400">journée</span>
      </h3>
      <p class="text-muted mb-4">
        Le rythme des journées est ponctué par des temps de prière, d'enseignements, de repas et des temps libres
        pour permettre un vrai repos et un réel ressourcement.
      </p>
      <p class="text-sm text-muted italic">
        Horaire indicatif, pouvant varier selon les retraites.
      </p>
    </Fragment>
    <Fragment slot="bg">
      <div class="absolute inset-0 bg-surface-special"></div>
    </Fragment>
  </Content>

  <Testimonials
    title="Paroles après six jours de silence"
    testimonials={[
      {
        testimonial: `Toute ma reconnaissance pour l'accueil chaleureux et le silence tellement habité de l'Essentiel.`,
        name: 'R.B.',
        job: 'Retraitant',
      },
      {
        testimonial: `La beauté simple de ce lieu sait si bien chanter Dieu !`,
        name: 'P. et R.G.',
        job: 'Couple retraitant',
      },
      {
        testimonial: `Quand je suis entré au Foyer, j'ai ressenti un immense sentiment de paix.`,
        name: 'François',
        job: 'Retraitant',
      },
    ]}
  >
    <Fragment slot="bg">
      <div class="absolute inset-0 bg-surface-alt"></div>
    </Fragment>
  </Testimonials>

  <!-- Maillage interne : infos pratiques -->
  <section class="py-8">
    <div class="max-w-3xl mx-auto px-4 sm:px-6 text-center">
      <p class="text-sm text-muted">
        Avant de vous inscrire, découvrez
        <a href="/sejour/journee-type" class="text-primary-600 hover:text-accent-500 underline underline-offset-2">la journée type</a> et
        <a href="/sejour/acces" class="text-primary-600 hover:text-accent-500 underline underline-offset-2">comment venir</a>.
        Vous pouvez aussi consulter le <a href="/programme" class="text-primary-600 hover:text-accent-500 underline underline-offset-2">programme complet</a>.
      </p>
    </div>
  </section>

  <CallToAction
    isDark
    actions={[
      {
        variant: 'primary',
        text: 'S\'inscrire',
        href: '/contact/inscription',
        icon: 'tabler:calendar-check',
      },
      {
        text: 'Découvrir les autres retraites',
        href: '/retraites',
      },
    ]}
  >
    <Fragment slot="title">
      Six jours pour <span class="text-accent-400">s'arrêter</span>
    </Fragment>
    <Fragment slot="subtitle">
      Le Foyer vous accueille. Inscrivez-vous ou contactez-nous pour toute question.
    </Fragment>
    <Fragment slot="bg">
      <div class="absolute inset-0 bg-primary-600"></div>
    </Fragment>
  </CallToAction>
</Layout>
