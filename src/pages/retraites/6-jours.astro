---
import Layout from '~/layouts/PageLayout.astro';
import Hero from '~/components/widgets/Hero.astro';
import Content from '~/components/widgets/Content.astro';
import Steps from '~/components/widgets/Steps.astro';
import Testimonials from '~/components/widgets/Testimonials.astro';
import CallToAction from '~/components/widgets/CallToAction.astro';
import { getUpcomingEvents, eventsToStepsItems, eventsToJsonLd, currentYear } from '~/utils/events';

import imgAutelHiver from '~/assets/images/fddm-autel-hiver.jpg';

const upcoming6jours = await getUpcomingEvents('6-jours');
const stepsItems = eventsToStepsItems(upcoming6jours);
const jsonLdEvents = eventsToJsonLd(upcoming6jours);

const metadata = {
  title: 'Retraite spirituelle de 6 jours en Suisse — Silence et enseignements',
  description: 'Retraite spirituelle de 6 jours en Suisse romande. Silence, enseignements, accompagnement individuel face aux Alpes. Foyer de Charité Dents-du-Midi, Bex.',
};
---

<Layout metadata={metadata}>
  {jsonLdEvents.map((schema) => (
    <script type="application/ld+json" set:html={JSON.stringify(schema)} />
  ))}

  <Hero>
    <Fragment slot="title">
      Un itinéraire <span class="text-accent-400">spirituel</span>
    </Fragment>
    <Fragment slot="subtitle">
      Six jours pour avancer dans la foi en approfondissant un thème particulier. Le cœur de la tradition des Foyers de Charité.
    </Fragment>
    <Fragment slot="bg">
      <div class="absolute inset-0">
        <img
          src="/images/fddm-croix-sommet-hiver.jpg"
          alt="Groupe de retraitants à la croix sommitale avec vue panoramique sur les Dents-du-Midi en hiver"
          class="w-full h-full object-cover"
          loading="eager"
        />
        <div class="absolute inset-0 bg-primary-900/60"></div>
      </div>
    </Fragment>
  </Hero>

  <Content
    tagline="Le format"
    title="Un itinéraire spirituel complet"
    image={{
      src: imgAutelHiver,
      alt: "L'autel de la chapelle en hiver, lieu de recueillement quotidien",
    }}
    items={[
      {
        title: 'Du dimanche soir au samedi matin',
        description: 'L\'arrivée se fait le dimanche avec l\'Eucharistie dominicale à 18h, suivie du repas à 19h.',
      },
      {
        title: 'Un thème pour chaque retraite',
        description: 'Un témoin de la foi, des paroles bibliques, un temps de l\'année liturgique, une dimension essentielle de la vie de foi...',
      },
      {
        title: 'En silence',
        description: 'Le silence favorise le ressourcement de chacun par le repos, l\'intériorité et le respect du cheminement de chacun.',
      },
      {
        title: 'Accompagnement personnel',
        description: 'Possibilité d\'un entretien personnel avec un prêtre. L\'Eucharistie (messe) quotidienne. L\'adoration.',
      },
    ]}
  >
    <Fragment slot="content">
      <h3 class="text-2xl font-bold tracking-tight sm:text-3xl mb-2 text-primary-600">
        Un itinéraire spirituel
      </h3>
      Six jours d'enseignements, de prière et de vie communautaire.
      Un temps qui se vit en silence pour favoriser le calme, le recueillement
      et le respect du cheminement de chacun.
    </Fragment>
    <Fragment slot="bg">
      <div class="absolute inset-0 bg-surface-alt"></div>
    </Fragment>
  </Content>

  <Steps
    title={`Prochaines dates ${currentYear}`}
    items={stepsItems}
  />

  <Content
    tagline="Une journée type"
    title="Le rythme d'une retraite de 6 jours"
    items={[
      {
        title: '7h00 — Laudes (prière du matin)',
        description: 'Prière en communauté.',
      },
      {
        title: '8h00 — Petit déjeuner',
        description: 'Silence.',
      },
      {
        title: '9h30 — Premier enseignement',
        description: 'Enseignement.',
      },
      {
        title: '11h45 — Eucharistie',
        description: 'Eucharistie (messe).',
      },
      {
        title: '13h00 — Repas de midi',
        description: 'Silence.',
      },
      {
        title: '14h30-17h30 — Temps libre',
        description: 'Promenade, lecture, accompagnement spirituel, adoration.',
      },
      {
        title: '17h30 — Deuxième enseignement',
        description: 'Enseignement.',
      },
      {
        title: '19h00 — Repas du soir',
        description: 'Silence.',
      },
      {
        title: '20h30 — Vêpres (prière du soir)',
        description: 'Prière en communauté.',
      },
    ]}
  >
    <Fragment slot="content">
      <h3 class="text-2xl font-bold tracking-tight sm:text-3xl mb-2 text-primary-600">
        Le rythme d'une journée
      </h3>
      Chaque journée est ponctuée par des temps de prière et d'enseignements — généralement deux conférences quotidiennes.
      Plusieurs temps libres permettent de se reposer, de se promener afin de profiter du magnifique parc aux alentours du Foyer,
      prolonger sa méditation ou encore bénéficier d'un entretien personnel avec un prêtre.
    </Fragment>
    <Fragment slot="bg">
      <div class="absolute inset-0 bg-surface-special"></div>
    </Fragment>
  </Content>

  <Testimonials
    title="Paroles après six jours de silence"
    testimonials={[
      {
        testimonial: `Toute ma reconnaissance pour l'accueil chaleureux et le silence tellement habité de l'Essentiel.`,
        name: 'R.B.',
        job: 'Retraitant',
      },
      {
        testimonial: `La beauté simple de ce lieu sait si bien chanter Dieu !`,
        name: 'P. et R.G.',
        job: 'Couple retraitant',
      },
      {
        testimonial: `Quand je suis entré au Foyer, j'ai ressenti un immense sentiment de paix.`,
        name: 'François',
        job: 'Retraitant',
      },
    ]}
  >
    <Fragment slot="bg">
      <div class="absolute inset-0 bg-surface-alt"></div>
    </Fragment>
  </Testimonials>

  <!-- Maillage interne : infos pratiques -->
  <section class="py-8">
    <div class="max-w-3xl mx-auto px-4 sm:px-6 text-center">
      <p class="text-sm text-muted">
        Avant de vous inscrire, découvrez
        <a href="/sejour/journee-type" class="text-primary-600 hover:text-accent-500 underline underline-offset-2">la journée type</a>,
        <a href="/sejour/tarifs" class="text-primary-600 hover:text-accent-500 underline underline-offset-2">les tarifs</a> et
        <a href="/sejour/acces" class="text-primary-600 hover:text-accent-500 underline underline-offset-2">comment venir</a>.
        Vous pouvez aussi consulter le <a href="/programme" class="text-primary-600 hover:text-accent-500 underline underline-offset-2">programme complet</a>.
      </p>
    </div>
  </section>

  <CallToAction
    isDark
    actions={[
      {
        variant: 'primary',
        text: 'S\'inscrire',
        href: '/contact/inscription',
        icon: 'tabler:calendar-check',
      },
      {
        text: 'Découvrir les autres retraites',
        href: '/retraites',
      },
    ]}
  >
    <Fragment slot="title">
      Six jours pour <span class="text-accent-400">s'arrêter</span>
    </Fragment>
    <Fragment slot="subtitle">
      Le Foyer vous accueille. Inscrivez-vous ou contactez-nous pour toute question.
    </Fragment>
    <Fragment slot="bg">
      <div class="absolute inset-0 bg-primary-600"></div>
    </Fragment>
  </CallToAction>
</Layout>
