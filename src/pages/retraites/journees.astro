---
import Layout from '~/layouts/PageLayout.astro';
import Hero from '~/components/widgets/Hero.astro';
import Content from '~/components/widgets/Content.astro';
import Steps from '~/components/widgets/Steps.astro';
import Testimonials from '~/components/widgets/Testimonials.astro';
import CallToAction from '~/components/widgets/CallToAction.astro';
import { getUpcomingEvents, eventsToStepsItems, eventsToJsonLd, currentYear } from '~/utils/events';

import imgCroixLysPaques from '~/assets/images/fddm-croix-lys-paques.jpg';

const upcomingJournees = await getUpcomingEvents('journees');
const stepsItems = eventsToStepsItems(upcomingJournees);
const jsonLdEvents = eventsToJsonLd(upcomingJournees);

const metadata = {
  title: 'Journées de ressourcement en Suisse — Foyer de Charité, Bex',
  description: 'Journées thématiques au Foyer de Charité Dents-du-Midi, Bex. Philosophie, littérature, art sacré : deux conférences, repas partagé et temps de recueillement. Ouvert à tous.',
};
---

<Layout metadata={metadata}>
  {jsonLdEvents.map((schema) => (
    <script type="application/ld+json" set:html={JSON.stringify(schema)} />
  ))}

  <Hero>
    <Fragment slot="title">
      Ressourcement et silence <span class="text-accent-400">pour tous</span>
    </Fragment>
    <Fragment slot="subtitle">
      Un thème, des intervenants, une journée pour approfondir et se laisser inspirer.
    </Fragment>
    <Fragment slot="bg">
      <div class="absolute inset-0">
        <img
          src="/images/fddm-automne-foyer.jpg"
          alt="Le Foyer de Charité Dents-du-Midi en automne, bâtisse jaune entourée de forêt"
          class="w-full h-full object-cover"
          loading="eager"
        />
        <div class="absolute inset-0 bg-primary-900/60"></div>
      </div>
    </Fragment>
  </Hero>

  <Content
    tagline="Le format"
    title="Des thématiques riches et variées"
    image={{
      src: imgCroixLysPaques,
      alt: 'Croix en bois avec lys blancs et chatons de saule, chapelle du Foyer',
    }}
    items={[
      {
        title: 'De 9h30 à 16h30',
        description: 'Une journée complète : accueil autour d\'un café, deux conférences, repas servi par la communauté et Eucharistie.',
      },
      {
        title: 'Des intervenants de qualité',
        description: 'Maurice Zundel, les fables de La Fontaine, l\'art de l\'icône, le silence intérieur... Chaque journée est portée par un thème et des intervenants passionnés.',
      },
      {
        title: 'Soyez les bienvenus',
        description: 'Vous ne connaissez pas le Foyer ? Venez comme vous êtes. Cette journée est faite pour vous.',
      },
    ]}
  >
    <Fragment slot="content">
      <h3 class="text-2xl font-bold tracking-tight sm:text-3xl mb-2 text-primary-600">
        Des rencontres qui nourrissent
      </h3>
      Philosophie, littérature, art sacré, silence intérieur : chaque journée est une invitation
      à explorer un sujet en profondeur, porté par des intervenants passionnés.
      Ouvert à tous, sans prérequis.
    </Fragment>
    <Fragment slot="bg">
      <div class="absolute inset-0 bg-surface-alt"></div>
    </Fragment>
  </Content>

  <Steps
    title={`Prochaines dates ${currentYear}`}
    items={stepsItems}
  />

  <Content
    tagline="Une journée type"
    title="Le déroulement d'une journée"
    items={[
      {
        title: '9h30 — Accueil',
        description: 'Accueil autour d\'une boisson (café ou autre).',
      },
      {
        title: '10h00 — Première conférence',
        description: 'Enseignement.',
      },
      {
        title: '11h15 — Silence et méditation',
        description: 'Silence et méditation personnelle.',
      },
      {
        title: '12h15 — Eucharistie',
        description: 'Eucharistie (messe).',
      },
      {
        title: '13h00 — Repas',
        description: 'Repas servi par la communauté.',
      },
      {
        title: '14h30 — Deuxième conférence',
        description: 'Enseignement.',
      },
      {
        title: '16h00 — Départ',
        description: 'Une boisson proposée avant de quitter le Foyer. Départ vers 16h30.',
      },
    ]}
  >
    <Fragment slot="content">
      <h3 class="text-2xl font-bold tracking-tight sm:text-3xl mb-2 text-primary-600">
        Un rythme équilibré
      </h3>
      Deux enseignements encadrent la journée. Entre les deux : prière, silence, repas partagé.
      Une respiration complète en quelques heures.
    </Fragment>
    <Fragment slot="bg">
      <div class="absolute inset-0 bg-surface-special"></div>
    </Fragment>
  </Content>

  <Testimonials
    title="Paroles après une journée"
    testimonials={[
      {
        testimonial: `Toute ma reconnaissance pour l'accueil chaleureux et le silence tellement habité de l'Essentiel.`,
        name: 'R.B.',
        job: 'Participant',
      },
      {
        testimonial: `La beauté simple de ce lieu sait si bien chanter Dieu !`,
        name: 'P. et R.G.',
        job: 'Couple participant',
      },
      {
        testimonial: `Quand je suis entré au Foyer, j'ai ressenti un immense sentiment de paix.`,
        name: 'François',
        job: 'Participant',
      },
    ]}
  >
    <Fragment slot="bg">
      <div class="absolute inset-0 bg-surface-alt"></div>
    </Fragment>
  </Testimonials>

  <!-- Maillage interne : infos pratiques -->
  <section class="py-8">
    <div class="max-w-3xl mx-auto px-4 sm:px-6 text-center">
      <p class="text-sm text-muted">
        Envie d'aller plus loin ? Découvrez les
        <a href="/retraites/week-ends" class="text-primary-600 hover:text-accent-500 underline underline-offset-2">week-ends</a> ou les
        <a href="/retraites/6-jours" class="text-primary-600 hover:text-accent-500 underline underline-offset-2">retraites de 6 jours</a>.
        Consultez aussi <a href="/sejour/acces" class="text-primary-600 hover:text-accent-500 underline underline-offset-2">comment venir</a> et le <a href="/programme" class="text-primary-600 hover:text-accent-500 underline underline-offset-2">programme complet</a>.
      </p>
    </div>
  </section>

  <CallToAction
    isDark
    actions={[
      {
        variant: 'primary',
        text: 'S\'inscrire à une journée',
        href: '/contact/inscription',
        icon: 'tabler:calendar-check',
      },
      {
        text: 'Découvrir les autres retraites',
        href: '/retraites',
      },
    ]}
  >
    <Fragment slot="title">
      Une journée pour <span class="text-accent-400">commencer</span>
    </Fragment>
    <Fragment slot="subtitle">
      Le Foyer vous accueille. Inscrivez-vous ou contactez-nous pour toute question.
    </Fragment>
    <Fragment slot="bg">
      <div class="absolute inset-0 bg-primary-600"></div>
    </Fragment>
  </CallToAction>
</Layout>
