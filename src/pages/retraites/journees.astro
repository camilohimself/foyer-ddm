---
import Layout from '~/layouts/PageLayout.astro';
import Hero from '~/components/widgets/Hero.astro';
import Content from '~/components/widgets/Content.astro';
import Steps from '~/components/widgets/Steps.astro';
import Testimonials from '~/components/widgets/Testimonials.astro';
import CallToAction from '~/components/widgets/CallToAction.astro';
import { getUpcomingEvents, eventsToStepsItems, eventsToJsonLd, currentYear } from '~/utils/events';

import imgCroixLysPaques from '~/assets/images/fddm-croix-lys-paques.jpg';

const upcomingJournees = await getUpcomingEvents('journees');
const stepsItems = eventsToStepsItems(upcomingJournees);
const jsonLdEvents = eventsToJsonLd(upcomingJournees);

const metadata = {
  title: 'Journée spirituelle en Suisse — Foyer de Charité, Bex',
  description: 'Journée spirituelle en Suisse romande. Enseignements, repas partagé et Eucharistie. Une porte d\'entrée pour découvrir le Foyer de Charité Dents-du-Midi, Bex.',
};
---

<Layout metadata={metadata}>
  {jsonLdEvents.map((schema) => (
    <script type="application/ld+json" set:html={JSON.stringify(schema)} />
  ))}

  <Hero>
    <Fragment slot="title">
      Une journée spirituelle au <span class="text-accent-400">Foyer</span>
    </Fragment>
    <Fragment slot="subtitle">
      Quelques heures pour se poser, écouter, prier. Une porte d'entrée toute simple.
    </Fragment>
    <Fragment slot="bg">
      <div class="absolute inset-0">
        <img
          src="/images/fddm-automne-foyer.jpg"
          alt="Le Foyer de Charité Dents-du-Midi en automne, bâtisse jaune entourée de forêt"
          class="w-full h-full object-cover"
          loading="eager"
        />
        <div class="absolute inset-0 bg-primary-900/60"></div>
      </div>
    </Fragment>
  </Hero>

  <Content
    tagline="Le format"
    title="Une porte d'entrée"
    image={{
      src: imgCroixLysPaques,
      alt: 'Croix en bois avec lys blancs et chatons de saule, chapelle du Foyer',
    }}
    items={[
      {
        title: 'De 9h30 à 16h30',
        description: 'Café d\'accueil, deux enseignements, repas partagé et Eucharistie.',
      },
      {
        title: 'CHF 50.-',
        description: 'L\'accueil, les enseignements et le repas sont compris.',
      },
      {
        title: 'Thèmes variés',
        description: 'Art, culture, spiritualité. Icônes, Maurice Zundel, La Fontaine, témoins de la foi.',
      },
      {
        title: 'Sans engagement',
        description: 'Vous ne connaissez pas le Foyer ? Cette journée est faite pour vous.',
      },
    ]}
  >
    <Fragment slot="content">
      <h3 class="text-2xl font-bold tracking-tight sm:text-3xl mb-2 text-primary-600">
        Quelques heures suffisent
      </h3>
      Pas besoin de plusieurs jours. Une journée suffit pour découvrir le Foyer,
      rencontrer d'autres chercheurs de sens, et repartir nourri.
    </Fragment>
    <Fragment slot="bg">
      <div class="absolute inset-0 bg-surface-alt"></div>
    </Fragment>
  </Content>

  <Steps
    title={`Prochaines dates ${currentYear}`}
    items={stepsItems}
  />

  <Content
    tagline="Une journée type"
    title="Le déroulement d'une journée"
    items={[
      {
        title: '9h30 — Accueil',
        description: 'Café d\'accueil, présentation de la journée.',
      },
      {
        title: '10h00 — Premier enseignement',
        description: 'Conférence du prédicateur (60-75 minutes).',
      },
      {
        title: '11h30 — Temps libre',
        description: 'Pause, promenade, silence.',
      },
      {
        title: '12h15 — Eucharistie',
        description: 'Messe.',
      },
      {
        title: '13h00 — Repas de midi',
        description: 'Repas en silence ou en échange libre selon la journée.',
      },
      {
        title: '14h30 — Deuxième enseignement',
        description: 'Seconde conférence (60-75 minutes).',
      },
      {
        title: '16h00 — Conclusion',
        description: 'Temps de partage ou questions, boisson, départ 16h30.',
      },
    ]}
  >
    <Fragment slot="content">
      <h3 class="text-2xl font-bold tracking-tight sm:text-3xl mb-2 text-primary-600">
        Un rythme équilibré
      </h3>
      Deux enseignements encadrent la journée. Entre les deux : prière, silence, repas partagé.
      Une respiration complète en quelques heures.
    </Fragment>
    <Fragment slot="bg">
      <div class="absolute inset-0 bg-surface-special"></div>
    </Fragment>
  </Content>

  <Testimonials
    title="Paroles après une journée"
    testimonials={[
      {
        testimonial: `Toute ma reconnaissance pour l'accueil chaleureux et le silence tellement habité de l'Essentiel.`,
        name: 'R.B.',
        job: 'Participant',
      },
      {
        testimonial: `La beauté simple de ce lieu sait si bien chanter Dieu !`,
        name: 'P. et R.G.',
        job: 'Couple participant',
      },
      {
        testimonial: `Quand je suis entré au Foyer, j'ai ressenti un immense sentiment de paix.`,
        name: 'François',
        job: 'Participant',
      },
    ]}
  >
    <Fragment slot="bg">
      <div class="absolute inset-0 bg-surface-alt"></div>
    </Fragment>
  </Testimonials>

  <Content
    tagline="Participation"
    title="Un prix simple"
    items={[
      {
        title: 'CHF 50.-',
        description: 'Café d\'accueil, deux enseignements, repas de midi, Eucharistie, boisson au départ.',
      },
      {
        title: 'Prix fixe',
        description: 'Contrairement aux retraites de plusieurs jours, le prix des journées est fixe.',
      },
      {
        title: 'S\'inscrire',
        description: 'Par téléphone au +41 24 463 18 78 ou via le <a href="/contact/inscription" class="text-primary-600 hover:text-accent-500 underline underline-offset-2">formulaire en ligne</a>.',
      },
    ]}
  >
    <Fragment slot="content">
      <h3 class="text-2xl font-bold tracking-tight sm:text-3xl mb-2 text-primary-600">
        CHF 50.- la journée
      </h3>
      L'accueil, les enseignements, le repas de midi et les boissons sont compris.
      Pour l'organisation du repas, merci de vous inscrire à l'avance.
    </Fragment>
  </Content>

  <!-- Maillage interne : infos pratiques -->
  <section class="py-8">
    <div class="max-w-3xl mx-auto px-4 sm:px-6 text-center">
      <p class="text-sm text-muted">
        Envie d'aller plus loin ? Découvrez les
        <a href="/retraites/week-end" class="text-primary-600 hover:text-accent-500 underline underline-offset-2">week-ends de 3 jours</a> ou les
        <a href="/retraites/6-jours" class="text-primary-600 hover:text-accent-500 underline underline-offset-2">retraites de 6 jours</a>.
        Consultez aussi <a href="/sejour/acces" class="text-primary-600 hover:text-accent-500 underline underline-offset-2">comment venir</a> et le <a href="/programme" class="text-primary-600 hover:text-accent-500 underline underline-offset-2">programme complet</a>.
      </p>
    </div>
  </section>

  <CallToAction
    isDark
    actions={[
      {
        variant: 'primary',
        text: 'S\'inscrire à une journée',
        href: '/contact/inscription',
        icon: 'tabler:calendar-check',
      },
      {
        text: 'Découvrir les autres retraites',
        href: '/retraites',
      },
    ]}
  >
    <Fragment slot="title">
      Une journée pour <span class="text-accent-400">commencer</span>
    </Fragment>
    <Fragment slot="subtitle">
      Le Foyer vous accueille. Inscrivez-vous ou contactez-nous pour toute question.
    </Fragment>
    <Fragment slot="bg">
      <div class="absolute inset-0 bg-primary-600"></div>
    </Fragment>
  </CallToAction>
</Layout>
