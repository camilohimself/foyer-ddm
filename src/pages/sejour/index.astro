---
import Layout from '~/layouts/PageLayout.astro';
import Hero from '~/components/widgets/Hero.astro';
import Content from '~/components/widgets/Content.astro';
import Features from '~/components/widgets/Features.astro';
import CallToAction from '~/components/widgets/CallToAction.astro';

import imgPaellaMontagnes from '~/assets/images/fddm-paella-montagnes.jpg';

const metadata = {
  title: 'Préparer votre séjour — Hébergement et infos pratiques à Bex',
  description: 'Préparez votre séjour au Foyer de Charité à Bex : chambres, journée type, tarifs et accès. Tout ce qu\'il faut savoir avant de venir en retraite.',
};
---

<Layout metadata={metadata}>
  <!-- Hero Section -->
  <Hero
    tagline="Informations pratiques"
    title="Préparer votre retraite"
    subtitle="Tout ce qu'il faut savoir avant de venir : chambres, rythme de la journée, participation et accès."
  >
    <Fragment slot="bg">
      <div class="absolute inset-0">
        <img
          src="/images/fddm-facade-ete.jpg"
          alt="La façade du Foyer de Charité en été, votre lieu de séjour"
          class="w-full h-full object-cover"
          loading="eager"
        />
        <div class="absolute inset-0 bg-primary-900/60"></div>
      </div>
    </Fragment>
  </Hero>

  <!-- Accueil et cuisine -->
  <Content
    isReversed
    image={{
      src: imgPaellaMontagnes,
      alt: 'Le cuisinier du Foyer prépare une paella en plein air, avec les Dents-du-Midi en arrière-plan',
    }}
  >
    <Fragment slot="content">
      <h3 class="text-2xl font-bold tracking-tight sm:text-3xl mb-2 text-primary-600">
        Accueillis comme <span class="text-accent-400">chez soi</span>
      </h3>
      <div class="space-y-4 text-muted">
        <p>
          Les repas sont préparés par la communauté avec soin. Cuisine maison, produits de saison,
          et parfois des surprises en plein air face aux montagnes.
        </p>
        <p>
          Tout est compris dans la participation : chambre, repas, enseignements et accompagnement.
          Vous n'avez qu'à venir. <a href="/contact/inscription" class="text-primary-600 hover:text-accent-500 underline underline-offset-2">Inscrivez-vous</a>.
        </p>
      </div>
    </Fragment>
  </Content>

  <!-- Hub des informations -->
  <Features
    id="infos-pratiques"
    title="Tout est <span class='text-accent-400'>prévu</span>"
    subtitle="Vous n'avez à penser à rien d'autre qu'à l'essentiel. Voici les informations pratiques."
    columns={2}
    items={[
      {
        title: 'Chambres',
        description:
          'Chambres individuelles ou doubles, literie et linge fournis. Un cadre de silence face aux montagnes.',
        icon: 'tabler:bed',
        callToAction: {
          text: 'En savoir plus',
          href: '/sejour/chambres',
        },
      },
      {
        title: 'Journée type',
        description:
          'De 8h à 21h : louange, conférences, adoration, eucharistie, prière. Un rythme équilibré entre enseignements, prière et temps personnels.',
        icon: 'tabler:clock',
        callToAction: {
          text: 'Découvrir le programme',
          href: '/sejour/journee-type',
        },
      },
      {
        title: 'Tarifs',
        description:
          'Participation suggérée d\'environ CHF 120.- par jour. L\'accueil, les repas et l\'hébergement sont compris. Chacun donne selon ses moyens.',
        icon: 'tabler:coin',
        callToAction: {
          text: 'Voir les tarifs',
          href: '/sejour/tarifs',
        },
      },
      {
        title: 'Accès',
        description:
          'Route de Gryon 22, 1880 Bex. À 50 min de Lausanne, 1h05 de Fribourg, 1h25 de Genève. Parking gratuit.',
        icon: 'tabler:map-pin',
        callToAction: {
          text: 'Comment venir',
          href: '/sejour/acces',
        },
      },
    ]}
  />

  <CallToAction
    isDark
    actions={[
      {
        variant: 'primary',
        text: "S'inscrire à une retraite",
        href: '/contact/inscription',
        icon: 'tabler:arrow-right',
      },
      {
        text: 'Voir le programme',
        href: '/programme',
      },
    ]}
  >
    <Fragment slot="title">Prêt à <span class="text-accent-400">venir</span> ?</Fragment>

    <Fragment slot="subtitle">
      Vous n'avez qu'à venir — le Foyer s'occupe du reste. Inscrivez-vous dès maintenant.<br />
      Personne n'est refusé pour des raisons financières.
    </Fragment>
    <Fragment slot="bg">
      <div class="absolute inset-0 bg-primary-600"></div>
    </Fragment>
  </CallToAction>
</Layout>
