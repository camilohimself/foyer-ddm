---
import Layout from '~/layouts/PageLayout.astro';
import Hero from '~/components/widgets/Hero.astro';
import Content from '~/components/widgets/Content.astro';
import CallToAction from '~/components/widgets/CallToAction.astro';
import imgChambreIndividuelle from '~/assets/images/fddm-chambre-individuelle.jpg';
import imgChambreDouble from '~/assets/images/fddm-chambre-double.jpg';
import imgChambreFamille from '~/assets/images/fddm-chambre-famille.jpg';

const metadata = {
  title: 'Les chambres — Hébergement en retraite',
  description: 'Chambres simples et confortables au Foyer de Charité à Bex. Hébergement en chambre individuelle ou double, dans un cadre de silence propice au ressourcement.',
};
---

<Layout metadata={metadata}>
  <Hero>
    <Fragment slot="title">
      Un cadre <span class="text-accent-400">simple et bon</span>
    </Fragment>
    <Fragment slot="subtitle">
      Des chambres pensées pour le repos et le silence. Tout le nécessaire, rien de superflu.
    </Fragment>
    <Fragment slot="bg">
      <div class="absolute inset-0">
        <img
          src="/images/fddm-facade-ete.jpg"
          alt="Le bâtiment du Foyer de Charité en été, chambres et hébergement"
          class="w-full h-full object-cover"
          loading="eager"
        />
        <div class="absolute inset-0 bg-primary-900/60"></div>
      </div>
    </Fragment>
  </Hero>

  <!-- Chambre individuelle -->
  <Content
    tagline="Hébergement"
    title="L'essentiel, sans le superflu"
    image={{ src: imgChambreIndividuelle, alt: 'Chambre individuelle du Foyer — lit, bureau, lavabo et balcon donnant sur la verdure' }}
    items={[
      {
        title: 'Chambre avec lavabo',
        description: 'Chaque chambre individuelle dispose d\'un lavabo. Douches et sanitaires partagés à l\'étage.',
      },
      {
        title: 'Calme et lumière',
        description: 'Balcon ou fenêtre ouvrant sur la verdure. Un espace de silence pour se retrouver.',
      },
    ]}
  >
    <Fragment slot="content">
      <h3 class="text-2xl font-bold tracking-tight sm:text-3xl mb-2 text-primary-600">
        Chambres individuelles
      </h3>
      Le Foyer n'est pas un hôtel. C'est un lieu de retraite. Les chambres sont simples, propres et silencieuses —
      tout est prévu pour que vous puissiez vous reposer et vivre pleinement votre retraite.
    </Fragment>
    <Fragment slot="bg">
      <div class="absolute inset-0 bg-surface-alt"></div>
    </Fragment>
  </Content>

  <!-- Chambre double -->
  <Content
    isReversed
    image={{ src: imgChambreDouble, alt: 'Chambre double du Foyer — deux lits, rideaux rouges, bureau et lumière naturelle' }}
    items={[
      {
        title: 'Deux lits séparés',
        description: 'Chambres spacieuses avec deux lits, bureau et chaise. Idéales pour les couples ou amis.',
      },
      {
        title: 'À préciser à l\'inscription',
        description: 'Le nombre de chambres doubles est limité. Indiquez votre préférence lors de l\'inscription.',
      },
    ]}
  >
    <Fragment slot="content">
      <h3 class="text-2xl font-bold tracking-tight sm:text-3xl mb-2 text-primary-600">
        Chambres doubles
      </h3>
      Quelques chambres doubles sont disponibles pour les couples ou les personnes souhaitant partager.
      Lumineuses et spacieuses, elles offrent le même cadre de silence et de repos.
    </Fragment>
  </Content>

  <!-- Chambre famille -->
  <Content
    image={{ src: imgChambreFamille, alt: 'Grande chambre familiale du Foyer — plusieurs lits, lavabo, deux fenêtres avec vue sur les arbres' }}
    items={[
      {
        title: 'Plusieurs lits',
        description: 'Chambres plus grandes avec plusieurs couchages, adaptées aux familles avec enfants.',
      },
      {
        title: 'Linge de lit fourni',
        description: 'Draps et serviettes sont fournis pour toutes les chambres. Apportez vos affaires de toilette.',
      },
    ]}
  >
    <Fragment slot="content">
      <h3 class="text-2xl font-bold tracking-tight sm:text-3xl mb-2 text-primary-600">
        Chambres familiales
      </h3>
      Pour les retraites en famille, des chambres plus spacieuses permettent d'accueillir parents et enfants
      dans un même espace. Lavabo intégré et vue sur le jardin.
    </Fragment>
    <Fragment slot="bg">
      <div class="absolute inset-0 bg-surface-alt"></div>
    </Fragment>
  </Content>

  <!-- Maillage interne -->
  <section class="py-8">
    <div class="max-w-3xl mx-auto px-4 sm:px-6 text-center">
      <p class="text-sm text-muted">
        Pour préparer votre séjour, consultez
        <a href="/sejour/journee-type" class="text-primary-600 hover:text-accent-500 underline underline-offset-2">le déroulement d'une journée</a>,
        <a href="/sejour/tarifs" class="text-primary-600 hover:text-accent-500 underline underline-offset-2">les tarifs</a> et
        <a href="/sejour/acces" class="text-primary-600 hover:text-accent-500 underline underline-offset-2">l'itinéraire pour venir</a>.
        Vous pouvez aussi parcourir <a href="/galerie" class="text-primary-600 hover:text-accent-500 underline underline-offset-2">la galerie photos</a>.
      </p>
    </div>
  </section>

  <CallToAction
    isDark
    actions={[
      {
        variant: 'primary',
        text: 'S\'inscrire à une retraite',
        href: '/contact/inscription',
        icon: 'tabler:calendar-check',
      },
      {
        text: 'Voir le programme',
        href: '/programme',
      },
    ]}
  >
    <Fragment slot="title">
      Venez <span class="text-accent-400">vous ressourcer</span>
    </Fragment>
    <Fragment slot="subtitle">
      Réservez votre place pour une retraite. Les chambres sont attribuées à l'arrivée.
    </Fragment>
    <Fragment slot="bg">
      <div class="absolute inset-0 bg-primary-600"></div>
    </Fragment>
  </CallToAction>
</Layout>
