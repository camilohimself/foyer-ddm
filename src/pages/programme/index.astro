---
import Layout from '~/layouts/PageLayout.astro';
import Hero from '~/components/widgets/Hero.astro';
import CallToAction from '~/components/widgets/CallToAction.astro';
import { getAllEvents, eventsToJsonLd, formatDateRange, today, currentYear } from '~/utils/events';

const allEvents = await getAllEvents();
const upcomingEvents = allEvents.filter((e) => (e.data.dateEnd || e.data.dateStart) >= today);
const pastEvents = allEvents.filter((e) => (e.data.dateEnd || e.data.dateStart) < today);

const metadata = {
  title: `Programme des retraites spirituelles ${currentYear}`,
  description: `${upcomingEvents.length} retraites spirituelles à venir au Foyer de Charité Dents-du-Midi, Bex. Journées, week-ends, retraites de 6 jours et préparation au mariage. Calendrier complet ${currentYear}.`,
};

// --- Mapping type → couleur texte + label + image par défaut ---
const typeConfig: Record<string, { textColor: string; badge: string; label: string; cardLabel: string; href: string; defaultImage: string }> = {
  '6-jours': { textColor: 'text-primary-800', badge: 'bg-primary-800', label: '6 jours', cardLabel: 'Retraite de six jours', href: '/retraites/6-jours', defaultImage: '/images/fddm-chapelle-etoile.jpg' },
  'week-end': { textColor: 'text-primary-500', badge: 'bg-primary-500', label: 'Week-end', cardLabel: '3 jours pour tous', href: '/retraites/week-ends', defaultImage: '/images/fddm-chapelle-tournesols.jpg' },
  couples: { textColor: 'text-rose-400', badge: 'bg-rose-300', label: 'Couples', cardLabel: '3 jours pour couples', href: '/retraites/week-ends#en-couple', defaultImage: '/images/fddm-couple-marche.jpg' },
  familles: { textColor: 'text-teal-500', badge: 'bg-teal-400/80', label: 'Familles', cardLabel: 'Week-end en famille', href: '/retraites/week-ends#en-famille', defaultImage: '/images/fddm-sentier-groupe.jpeg' },
  journees: { textColor: 'text-accent-500', badge: 'bg-accent-400', label: 'Journée', cardLabel: 'Journées', href: '/retraites/journees', defaultImage: '/images/fddm-dents-du-midi-printemps.jpg' },
  mariage: { textColor: 'text-violet-400', badge: 'bg-violet-300', label: 'Mariage', cardLabel: 'Préparation au mariage', href: '/retraites/preparation-mariage', defaultImage: '/images/fddm-couple-mains.jpg' },
};

// --- Grouper les événements par mois ---
const monthNames = ['Janvier', 'Février', 'Mars', 'Avril', 'Mai', 'Juin', 'Juillet', 'Août', 'Septembre', 'Octobre', 'Novembre', 'Décembre'];

function groupByMonth(events: typeof upcomingEvents) {
  const groups: { key: string; label: string; events: typeof upcomingEvents }[] = [];
  for (const event of events) {
    const d = new Date(event.data.dateStart + 'T12:00:00');
    const key = `${d.getFullYear()}-${String(d.getMonth()).padStart(2, '0')}`;
    const label = `${monthNames[d.getMonth()]} ${d.getFullYear()}`;
    let group = groups.find((g) => g.key === key);
    if (!group) {
      group = { key, label, events: [] };
      groups.push(group);
    }
    group.events.push(event);
  }
  return groups;
}

const upcomingByMonth = groupByMonth(upcomingEvents);

// --- JSON-LD events data (all events for SEO) ---
const jsonLdEvents = eventsToJsonLd(allEvents);
---

<Layout metadata={metadata}>
  {jsonLdEvents.map((schema) => (
    <script is:inline type="application/ld+json" set:html={JSON.stringify(schema)} />
  ))}

  <Hero>
    <Fragment slot="title">
      <span class="font-playball text-7xl md:text-8xl lg:text-9xl leading-tight">« Venez et <span class="text-accent-400">voyez</span> »</span><br /><span class="text-sm font-normal tracking-wide opacity-60 mt-2 inline-block">Jn 1, 39</span>
    </Fragment>
    <Fragment slot="subtitle">
      Découvrez le programme des retraites au Foyer de Charité Dents-du-Midi, Bex.
      Journées, week-ends, retraites de 6 jours et préparation au mariage.
    </Fragment>
    <Fragment slot="bg">
      <div class="absolute inset-0">
        <img
          src="/images/fddm-contemplation-dents-du-midi.jpg"
          alt="Femme assise contemplant les Dents-du-Midi en été, programme des retraites 2026"
          class="w-full h-full object-cover"
          loading="eager"
        />
        <div class="absolute inset-0 bg-primary-900/60"></div>
      </div>
    </Fragment>
  </Hero>

  <section class="py-12 md:py-20">
    <div class="max-w-5xl mx-auto px-4 sm:px-6">
      <!-- Filtres par type -->
      <div id="event-filters" class="flex flex-wrap gap-2 mb-12 justify-center">
        <button data-filter="all" class="filter-btn active inline-flex items-center gap-1.5 text-sm px-3 py-1.5 rounded-full border border-gray-200 bg-primary-800 text-white transition-all cursor-pointer">
          Tout
        </button>
        <button data-filter="journees" class="filter-btn inline-flex items-center gap-1.5 text-sm px-3 py-1.5 rounded-full border border-gray-200 hover:border-gray-300 transition-all cursor-pointer">
          <span class="w-3 h-3 rounded-full bg-accent-400 shrink-0"></span> Journée
        </button>
        <button data-filter="week-end" class="filter-btn inline-flex items-center gap-1.5 text-sm px-3 py-1.5 rounded-full border border-gray-200 hover:border-gray-300 transition-all cursor-pointer">
          <span class="w-3 h-3 rounded-full bg-primary-500 shrink-0"></span> Week-end
        </button>
        <button data-filter="6-jours" class="filter-btn inline-flex items-center gap-1.5 text-sm px-3 py-1.5 rounded-full border border-gray-200 hover:border-gray-300 transition-all cursor-pointer">
          <span class="w-3 h-3 rounded-full bg-primary-800 shrink-0"></span> 6 jours
        </button>
        <button data-filter="couples" class="filter-btn inline-flex items-center gap-1.5 text-sm px-3 py-1.5 rounded-full border border-gray-200 hover:border-gray-300 transition-all cursor-pointer">
          <span class="w-3 h-3 rounded-full bg-rose-300 shrink-0"></span> Couples
        </button>
        <button data-filter="familles" class="filter-btn inline-flex items-center gap-1.5 text-sm px-3 py-1.5 rounded-full border border-gray-200 hover:border-gray-300 transition-all cursor-pointer">
          <span class="w-3 h-3 rounded-full bg-teal-400/80 shrink-0"></span> Familles
        </button>
        <button data-filter="mariage" class="filter-btn inline-flex items-center gap-1.5 text-sm px-3 py-1.5 rounded-full border border-gray-200 hover:border-gray-300 transition-all cursor-pointer">
          <span class="w-3 h-3 rounded-full bg-violet-300 shrink-0"></span> Mariage
        </button>
      </div>

      <!-- Retraites à venir — groupées par mois -->
      <div id="events-list">
        {upcomingByMonth.map((month) => (
          <div class="month-group mb-12" data-month={month.key}>
            <h2 class="text-2xl md:text-3xl font-bold uppercase tracking-wide text-gray-800">{month.label}</h2>
            <div class="h-0.5 bg-accent-400 mt-3 mb-8"></div>

            {month.events.map((event, idx) => {
              const info = typeConfig[event.data.type] || { textColor: 'text-gray-500', badge: 'bg-gray-500', label: event.data.type, cardLabel: event.data.type, href: '#', defaultImage: '/images/fddm-chapelle-etoile.jpg' };
              const eventImage = event.data.image || info.defaultImage;
              return (
                <>
                  <div class="event-card flex flex-col md:flex-row gap-6 py-6" data-type={event.data.type}>
                    {/* Photo */}
                    <div class="md:w-72 shrink-0">
                      <img
                        src={eventImage}
                        alt={event.data.title}
                        class="w-full h-44 md:h-40 object-cover rounded"
                        loading="lazy"
                      />
                    </div>

                    {/* Contenu */}
                    <div class="flex-1 min-w-0">
                      <p class={`text-sm font-medium ${info.textColor} mb-1`}>{info.cardLabel}</p>
                      <h3 class="text-xl md:text-2xl font-medium text-gray-800 mb-2">{event.data.title}</h3>
                      <p class="text-sm text-gray-500 mb-0.5">
                        {event.data.dateDetails || formatDateRange(event.data.dateStart, event.data.dateEnd)}
                      </p>
                      <p class="text-sm text-gray-500">
                        Intervenant: {event.data.preacher}
                      </p>
                      {event.data.variant && (
                        <p class="text-sm text-accent-500 font-medium mt-1">
                          {event.data.variant}
                        </p>
                      )}
                    </div>

                    {/* Boutons */}
                    <div class="flex md:flex-col lg:flex-row gap-2 md:self-center shrink-0">
                      <a
                        href={`/programme/${event.id}`}
                        class="inline-flex items-center justify-center text-sm font-medium border border-gray-300 text-gray-600 px-6 py-2.5 rounded-full hover:bg-gray-50 transition"
                      >
                        Infos
                      </a>
                      {event.data.externalUrl ? (
                        <a
                          href={event.data.externalUrl}
                          target="_blank"
                          rel="noopener noreferrer"
                          class="inline-flex items-center justify-center text-sm font-semibold bg-accent-400 text-white px-6 py-2.5 rounded-full hover:bg-accent-300 transition"
                        >
                          Inscription
                        </a>
                      ) : (
                        <a
                          href={`/contact/inscription?retraite=${event.id}`}
                          class="inline-flex items-center justify-center text-sm font-semibold bg-accent-400 text-white px-6 py-2.5 rounded-full hover:bg-accent-300 transition"
                        >
                          Inscription
                        </a>
                      )}
                    </div>
                  </div>
                  {/* Séparateur orange entre les événements */}
                  {idx < month.events.length - 1 && (
                    <div class="border-b border-accent-400/30"></div>
                  )}
                </>
              );
            })}
          </div>
        ))}
      </div>

      <!-- Retraites passées (SEO preserved) -->
      {pastEvents.length > 0 && (
        <details class="mt-16">
          <summary class="cursor-pointer text-sm text-gray-400 hover:text-primary-600 transition-colors select-none py-3 border-t border-gray-100">
            Retraites passées ({pastEvents.length})
          </summary>
          <div class="space-y-3 mt-4">
            {pastEvents.map((event) => {
              const info = typeConfig[event.data.type] || { textColor: 'text-gray-500', badge: 'bg-gray-500', label: event.data.type, href: '#', defaultImage: '' };
              return (
                <div class="flex flex-col sm:flex-row gap-4 p-4 rounded-lg border border-gray-100 bg-gray-50/50 opacity-60">
                  <div class="sm:w-44 shrink-0">
                    <div class="text-sm text-gray-400">
                      {formatDateRange(event.data.dateStart, event.data.dateEnd)}
                    </div>
                    <span class={`inline-block mt-1 text-xs font-medium text-white px-2.5 py-0.5 rounded-full ${info.badge} opacity-50`}>
                      {info.label}
                    </span>
                  </div>
                  <div class="flex-1">
                    <h3 class="text-base font-medium text-gray-500">{event.data.title}</h3>
                    <p class="text-sm text-gray-400 mt-0.5">
                      {event.data.preacher}
                      {event.data.variant && <span class="ml-2">· {event.data.variant}</span>}
                    </p>
                  </div>
                  <div class="sm:self-center shrink-0">
                    <span class="text-xs text-gray-400">Terminée</span>
                  </div>
                </div>
              );
            })}
          </div>
        </details>
      )}
    </div>
  </section>

  <CallToAction
    isDark
    actions={[
      {
        variant: 'primary' as const,
        text: "S'inscrire à une retraite",
        href: '/contact/inscription',
        icon: 'tabler:arrow-right',
      },
      {
        text: 'Nous appeler',
        href: 'tel:+41244632222',
      },
    ]}
  >
    <Fragment slot="title">
      Franchir le <span class="text-accent-400">pas</span>
    </Fragment>
    <Fragment slot="subtitle">
      Les portes du Foyer sont ouvertes. Inscrivez-vous ou contactez-nous pour toute question.<br />
      Personne n'est refusé pour des raisons financières.
    </Fragment>
    <Fragment slot="bg">
      <div class="absolute inset-0 bg-primary-600"></div>
    </Fragment>
  </CallToAction>

  <style>
    .filter-btn {
      background-color: white;
      color: #374151;
    }
    .filter-btn.active {
      background-color: #112F41;
      color: white;
      border-color: #112F41;
    }
    .filter-btn:not(.active):hover {
      background-color: #f3f4f6;
    }
    .event-card {
      transition: opacity 0.2s ease, transform 0.2s ease;
    }
    .event-card.hidden-by-filter {
      display: none;
    }
    /* Cacher le séparateur si l'event suivant est filtré */
    .event-card.hidden-by-filter + .border-b {
      display: none;
    }
    /* Cacher les groupes de mois vides */
    .month-group.hidden-month {
      display: none;
    }
  </style>

  <script>
    const filters = document.querySelectorAll<HTMLButtonElement>('#event-filters .filter-btn');
    const cards = document.querySelectorAll<HTMLDivElement>('.event-card');
    const monthGroups = document.querySelectorAll<HTMLDivElement>('.month-group');

    filters.forEach((btn) => {
      btn.addEventListener('click', () => {
        const type = btn.dataset.filter;

        // Toggle: if already active and not "all", deactivate → show all
        if (btn.classList.contains('active') && type !== 'all') {
          btn.classList.remove('active');
          document.querySelector('[data-filter="all"]')?.classList.add('active');
          cards.forEach((card) => card.classList.remove('hidden-by-filter'));
          monthGroups.forEach((g) => g.classList.remove('hidden-month'));
          return;
        }

        // Update active state
        filters.forEach((b) => b.classList.remove('active'));
        btn.classList.add('active');

        // Filter cards
        cards.forEach((card) => {
          if (type === 'all' || card.dataset.type === type) {
            card.classList.remove('hidden-by-filter');
          } else {
            card.classList.add('hidden-by-filter');
          }
        });

        // Cacher les mois vides
        monthGroups.forEach((group) => {
          const visibleCards = group.querySelectorAll('.event-card:not(.hidden-by-filter)');
          if (visibleCards.length === 0) {
            group.classList.add('hidden-month');
          } else {
            group.classList.remove('hidden-month');
          }
        });
      });
    });
  </script>
</Layout>
