---
import Layout from '~/layouts/PageLayout.astro';
import CallToAction from '~/components/widgets/CallToAction.astro';
import { getCollection, render } from 'astro:content';
import { formatDateRange, today } from '~/utils/events';

export async function getStaticPaths() {
  const events = await getCollection('event');
  return events.map((event) => ({
    params: { slug: event.id },
    props: { event },
  }));
}

const { event } = Astro.props;
const { Content } = await render(event);
const isPast = (event.data.dateEnd || event.data.dateStart) < today;

const metadata = {
  title: `${event.data.title} — Retraite au Foyer de Charité`,
  description: `${event.data.title} — ${event.data.preacher}. ${event.data.dateDetails || formatDateRange(event.data.dateStart, event.data.dateEnd)}. Retraite spirituelle au Foyer de Charité Dents-du-Midi, Bex.`,
};
---

<Layout metadata={metadata}>
  <section class="py-8 md:py-12">
    <div class="max-w-3xl mx-auto px-4 sm:px-6">

      <!-- Retour programme -->
      <a href="/programme" class="inline-flex items-center gap-1.5 text-sm text-primary-600 hover:text-accent-500 transition-colors mb-8">
        ← Retour au programme
      </a>

      {isPast && (
        <div class="mb-8 p-4 rounded-xl bg-gray-100 border border-gray-200 flex items-center gap-3">
          <svg class="w-5 h-5 text-gray-400 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>
          <p class="text-sm text-gray-500">Cette retraite est terminée. <a href="/programme" class="text-primary-600 hover:text-accent-500 underline underline-offset-2">Voir les prochaines retraites</a></p>
        </div>
      )}

      <!-- Photo placeholder -->
      {event.data.image ? (
        <img
          src={event.data.image}
          alt={event.data.title}
          class="w-full h-64 md:h-96 object-cover rounded-lg mb-8"
        />
      ) : (
        <div class="w-full h-64 md:h-96 bg-gray-100 rounded-lg mb-8 flex items-center justify-center">
          <div class="text-center text-gray-300">
            <svg class="w-16 h-16 mx-auto mb-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z" />
            </svg>
            <span class="text-sm">Photo à venir</span>
          </div>
        </div>
      )}

      <!-- Dates + variant -->
      <p class="text-lg text-gray-600 mb-2">
        {event.data.dateDetails || formatDateRange(event.data.dateStart, event.data.dateEnd)}
        {event.data.variant && (
          <span> — <strong class="text-gray-800">- {event.data.variant} -</strong></span>
        )}
      </p>

      <!-- Title -->
      <h1 class="text-3xl md:text-4xl font-bold text-primary-800 mb-4 font-heading">
        {event.data.title}
      </h1>

      <hr class="border-gray-200 mb-6" />

      <!-- Preacher -->
      <p class="text-base font-semibold text-accent-500 mb-8">
        Avec {event.data.preacher}
      </p>

      <!-- Content -->
      <div class="prose prose-lg max-w-none text-gray-700 mb-12">
        <Content />
      </div>

      <!-- CTAs -->
      <div class="flex flex-col sm:flex-row gap-4">
        {!isPast && event.data.registrationOpen && !event.data.externalUrl && (
          <a
            href={`/contact/inscription?retraite=${event.id}`}
            class="inline-flex items-center justify-center text-base font-semibold bg-accent-400 text-white px-8 py-3 rounded-full hover:bg-accent-300 transition"
          >
            S'inscrire à cette retraite
          </a>
        )}
        {!isPast && event.data.externalUrl && (
          <a
            href={event.data.externalUrl}
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center justify-center text-base font-semibold bg-accent-400 text-white px-8 py-3 rounded-full hover:bg-accent-300 transition"
          >
            S'inscrire ↗
          </a>
        )}
        {isPast ? (
          <a
            href="/programme"
            class="inline-flex items-center justify-center text-base font-semibold bg-primary-600 text-white px-8 py-3 rounded-full hover:bg-primary-500 transition"
          >
            Voir les prochaines retraites
          </a>
        ) : (
          <a
            href="tel:+41244632222"
            class="inline-flex items-center justify-center text-base font-medium border border-gray-300 text-primary-700 px-8 py-3 rounded-full hover:bg-gray-50 transition"
          >
            Nous appeler
          </a>
        )}
      </div>
    </div>
  </section>

  <CallToAction
    isDark
    actions={[
      {
        variant: 'primary',
        text: 'Voir tout le programme',
        href: '/programme',
        icon: 'tabler:arrow-right',
      },
    ]}
  >
    <Fragment slot="title">
      Découvrir les autres <span class="text-accent-400">retraites</span>
    </Fragment>
    <Fragment slot="subtitle">
      Consultez le programme complet des retraites au Foyer de Charité Dents-du-Midi.
    </Fragment>
    <Fragment slot="bg">
      <div class="absolute inset-0 bg-primary-600"></div>
    </Fragment>
  </CallToAction>
</Layout>
