---
import Layout from '~/layouts/PageLayout.astro';
import Hero from '~/components/widgets/Hero.astro';

const metadata = {
  title: 'Inscription confirmée — Newsletter du Foyer',
  description: 'Merci pour votre inscription à la newsletter du Foyer de Charité Dents-du-Midi.',
  robots: { index: false, follow: true },
};
---

<Layout metadata={metadata}>
  <Hero
    actions={[
      {
        text: 'Retour à l\'accueil',
        href: '/',
        icon: 'tabler:arrow-left',
      },
    ]}
  >
    <Fragment slot="title">
      <span class="text-accent-400">Merci</span>, c'est noté
    </Fragment>
    <Fragment slot="subtitle">
      Vous recevrez les nouvelles du Foyer directement dans votre boîte mail.
    </Fragment>
    <Fragment slot="bg">
      <div class="absolute inset-0">
        <img
          src="/images/fddm-facade-ete.jpg"
          alt="Le Foyer de Charité Dents-du-Midi"
          class="w-full h-full object-cover"
          loading="eager"
        />
        <div class="absolute inset-0 bg-primary-900/60"></div>
      </div>
    </Fragment>
  </Hero>
</Layout>
